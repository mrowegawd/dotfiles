set -g window-status-format "#[fg=$TMUX_FG,bold]´Ĺä #I:#{b:pane_current_path}"
set -g window-status-current-format "#[fg=red,bold]´Ĺä #I:#{b:pane_current_path}#[bg=red,fg=$COL_ACTIVE_BORDER_SEPERATOR,bold]#{?window_zoomed_flag, ZOOM #[fg=$COL_ACTIVE_BORDER_SEPERATOR](#(tmux list-panes | wc -l)) ,}"

