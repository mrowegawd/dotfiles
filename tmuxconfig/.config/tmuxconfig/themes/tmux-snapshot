WINDOW_ACTIVE_BG="#282828"
WINDOW_NONACTIVE_BG="#3c3836"

COL_WHITE="#626262"

BG_STATUSLINE="#504945"
BG_ACTIVE_STATUSLINE="#d5c4a1"

left_separator='о‚±'
# left_separator_black='о‚ґ'
left_separator_black='о‚°'
right_separator='о‚і'
right_separator_black='о‚¶'
session_symbol=''

window_status_current_fg=colour16 # black
window_status_current_bg=colour4 # blue

set -g pane-border-style bg=$WINDOW_NONACTIVE_BG,fg=$WINDOW_ACTIVE_BG
setw -g pane-active-border-style bg=$WINDOW_NONACTIVE_BG,fg=$WINDOW_ACTIVE_BG

setw -g window-style bg=$WINDOW_NONACTIVE_BG
setw -g window-active-style bg=$WINDOW_ACTIVE_BG

set -g status-fg colour8
set -g status-bg $BG_STATUSLINE

## STATUS SETTINGS
  set -g status-position bottom
  set -g status on
  set -g status-interval 5
  set -g status-justify left

## LEFT
  set -g status-left-length 40
  set -g status-style bg="colour238",fg="colour255"
  set -g status-left "#[fg=$COL_WHITE,bg=$WINDOW_NONACTIVE_BG,bold] вќђ #S \
#[fg=$WINDOW_NONACTIVE_BG,bg=$BG_STATUSLINE,nobold]$left_separator_black"

## NON/ACTIVE WINDOW
  set -g window-status-format "#[fg=$COL_WHITE] #I #W"
  set -g window-status-current-format "#[fg=$BG_STATUSLINE,bg=$BG_ACTIVE_STATUSLINE]$left_separator_black\
#[fg=$window_status_current_fg,bg=$BG_ACTIVE_STATUSLINE,bold] #I \
$left_separator #W #[fg=$BG_ACTIVE_STATUSLINE,bg=$BG_STATUSLINE,nobold]$left_separator_black\
#[bg=$WINDOW_NONACTIVE_BG,fg=red,bold]#{?window_zoomed_flag, ZOOM ,}"

## RIGHT
  set -g status-right-length 40
  set -g status-right "#[fg=$COL_WHITE] пЊѓ  #(lsb_release -d | cut -f 2) "

