WINDOW_STYLE_BG="#3d3f52"
WINDOW_ACTIVE_STYLE_BG="#514C75"

COL_WHITE="#626262"

BG_STATUSLINE="#2E2F3E"
BG_ACTIVE_STATUSLINE="#7ef5b8"

left_separator='¯é▒'
# left_separator_black='¯é┤'
left_separator_black='¯é░'
right_separator='¯é│'
right_separator_black='¯éÂ'
session_symbol=''

window_status_current_fg=colour3 # black
window_status_current_bg=colour4 # blue

setw -g pane-border-style bg=$WINDOW_ACTIVE_STYLE_BG,fg=$COL_WHITE
setw -g pane-active-border-style bg=$WINDOW_ACTIVE_STYLE_BG,fg=$COL_WHITE

setw -g window-style bg=$WINDOW_ACTIVE_STYLE_BG
setw -g window-active-style bg=$WINDOW_STYLE_BG

set -g status-fg colour8
set -g status-bg $WINDOW_STYLE_BG

## STATUS SETTINGS
set -g status-position bottom
set -g status on
set -g status-interval 5
set -g status-justify 'left'  #left,centre,??
set -g message-style "fg=$WINDOW_ACTIVE_BG,bg=$BG_ACTIVE_STATUSLINE bold"

## PANE THEME
set -wg pane-border-status top
set -wg pane-border-format '#[align=right] #{?#{&&:#{pane_active},#{client_prefix}},#[underscore],}\
#{pane_current_command} ´àÀ #{pane_tty} #{?pane_active,ÔØÉ #S:#I/#{session_windows} ,}\
#{?window_zoomed_flag,Ô¼ó,ÔØä} #P '

## LEFT
set -g status-left-length 40
set -g status-style bg="colour238",fg="colour255"
set -g status-left "#[fg=$COL_WHITE,bg=$WINDOW_NONACTIVE_BG,bold] ÔØÉ #S \
#[fg=$WINDOW_NONACTIVE_BG,bg=$BG_STATUSLINE,nobold]$left_separator_black"

set -g window-status-format "#[fg=$COL_WHITE] #I #W"
set -g window-status-current-format "#[fg=$BG_STATUSLINE,bg=$BG_ACTIVE_STATUSLINE]$left_separator_black\
#[fg=$WINDOW_ACTIVE_BG,bg=$BG_ACTIVE_STATUSLINE,bold] #I \
$left_separator #W #[fg=$BG_ACTIVE_STATUSLINE,bg=$BG_STATUSLINE,nobold]$left_separator_black\
#[bg=$WINDOW_NONACTIVE_BG,fg=red,bold]#{?window_zoomed_flag, ZOOM ,}"

## RIGHT
set -g status-right-length 40
