right_separator='о‚і'
right_separator_black='о‚¶'
session_symbol=''

window_status_current_fg=colour3 # black
window_status_current_bg=colour4 # blue

setw -g pane-border-style bg=$WINDOW_ACTIVE_STYLE_BG,fg=$COL_BORDER_SEPERATOR
setw -g pane-active-border-style bg=$WINDOW_ACTIVE_STYLE_BG,fg=$COL_BORDER_SEPERATOR

setw -g window-style bg=$WINDOW_ACTIVE_STYLE_BG
setw -g window-active-style bg=$WINDOW_STYLE_BG

set -g status-fg $WINDOW_STYLE_BG
set -g status-bg $BG_STATUSLINE

## STATUS SETTINGS
set -g status-position top
set -g status on
set -g status-interval 5
set -g status-justify 'left'  #left,centre,??
set -g message-style "fg=$WINDOW_STYLE_BG,bg=$BG_ACTIVE_STATUSLINE bold"

