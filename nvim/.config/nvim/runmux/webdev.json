{
  "name": "webdev",
  "run_file": {
    "include_cwd": false,
    "command": "yarn run_tsc"
  },
  "repl": {
    "open_pane": "tmux split-window -h -p 20",
    "command": "node"
  },
  "tasks": {
    "layout": [
      {
        "open_pane": "tmux split-window -v -p 20",
        "command": "yarn dev"
      },
      {
        "open_pane": "tmux split-window -h -p 50",
        "command": ""
      }
    ]
  }
}
