{
  "suggest.detailField": "abbr",
  "suggest.echodocSupport": true,
  "suggest.enablePreview": true,
  "suggest.languageSourcePriority": 99,
  "suggest.maxPreviewWidth": 1000,
  "suggest.noselect": false,
  "suggest.removeDuplicateItems": true,
  "suggest.snippetIndicator": " ",
  "suggest.timeout": 500,
  "suggest.completionItemKindLabels": {
    "keyword": " [keyword]",
    "variable": " [variable]",
    "value": " [value]",
    "operator": "Ψ [operator]",
    "function": "ƒ [function]",
    "reference": "渚 [reference]",
    "constant": " [constant]",
    "method": " [method]",
    "struct": "פּ [struct]",
    "class": " [class]",
    "interface": " [interface]",
    "text": " [text]",
    "enum": " [enum]",
    "enumMember": " [enumMember]",
    "module": " [module]",
    "color": " [color]",
    "property": " [property]",
    "field": "料 [field]",
    "unit": " [unit]",
    "event": "鬒 [event]",
    "file": " [file]",
    "folder": " [folder]",
    "Snippet": " [snippet]",
    "typeParameter": " [typeParameter]",
    "default": " [default]"
  },
  "codeLens.enable": true,
  "coc.source.file.shortcut": "F",
  "coc.source.file.priority": 89,
  "coc.source.file.ignoreHidden": false,
  "coc.source.buffer.shortcut": "B",
  "coc.source.buffer.priority": 10,
  "coc.source.buffer.ignoreGitignore": false,
  "coc.source.around.shortcut": "A",
  "coc.source.around.priority": 88,
  "coc.preferences.formatOnType": true,
  "coc.preferences.hoverTarget": "float",
  "coc.preferences.messageLevel": "error",
  "coc.preferences.formatOnSaveFiletypes": [
    "c",
    "cpp",
    "go",
    "javascript",
    "json",
    "jsonc",
    "python",
    "typescript"
  ],
  "list.indicator": "➤",
  "list.normalMappings": {
    "t": "action:tabe",
    "d": "expr:GetDeleteAction",
    "<C-v>": "action:vsplit",
    "<C-s>": "action:split",
    "<C-p>": "action:drop"
  },
  "list.insertMappings": {
    "<C-t>": "action:tabe",
    "<C-w>": "command:wincmd k",
    "<C-v>": "action:vsplit",
    "<C-s>": "action:split",
    "<C-p>": "action:drop"
  },
  "snippets.priority": 80,
  "snippets.extends": {
    "cpp": ["c"],
    "javascriptreact": ["javascript"],
    "typescript": ["javascript"]
  },
  // javascript
  "javascript.validate.enable": false,
  // TYPESCRIPT
  "typescript.validate.enable": true,
  "typescript.suggest.enabled": true
}
