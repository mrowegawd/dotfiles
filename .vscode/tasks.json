{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Task: run_file",
      "type": "shell",
      "command": "lua",
      "args": ["${fileBasename}"],
      "problemMatcher": []
    },
    {
      "label": "Orchestrations: run all tail task",
      "type": "shell",
      "dependsOn": ["Tail lsp.log", "Tail nvim log", "Tail journalctl"]
    },
    {
      "label": "Tail lsp.log",
      "type": "shell",
      "command": "tail",
      "args": ["-f", "$HOME/.local/state/nvim/lsp.log"],
      "problemMatcher": []
    },
    {
      "label": "Tail nvim log",
      "type": "shell",
      "command": "tail",
      "args": ["-f", "$HOME/.local/state/nvim/log"],
      "problemMatcher": []
    },
    {
      "label": "Tail journalctl",
      "type": "shell",
      "command": "journalctl",
      "args": ["-f", "-n", "50", "-q"],
      "problemMatcher": []
    },
    {
      "label": "Tail noice.log",
      "type": "shell",
      "command": "tail",
      "args": ["-f", "$HOME/.local/state/nvim/noice.log"],
      "problemMatcher": []
    },
    {
      "label": "Tail conform log",
      "type": "shell",
      "command": "tail",
      "args": ["-f", "$HOME/.local/state/nvim/conform.log"],
      "problemMatcher": []
    },
    {
      "label": "Orchestrations: debug mark",
      "type": "shell",
      "dependsOn": ["Check watch mark", "Cat data mark"]
    },
    {
      "label": "Check watch mark",
      "type": "shell",
      "command": "watch",
      "args": [
        "-n",
        "1",
        "ls",
        "-la",
        "$HOME/Dropbox/neorg/orgmode/nvim-plugin/qfbookmark/dotfiles-e76759d5fc3b1a7eeb3562a2509046c1110adf02"
      ],
      "problemMatcher": []
    },
    {
      "label": "Cat data mark",
      "type": "shell",
      "command": "watch",
      "args": [
        "-n",
        "1",
        "cat",
        "$HOME/Dropbox/neorg/orgmode/nvim-plugin/qfbookmark/dotfiles-e76759d5fc3b1a7eeb3562a2509046c1110adf02/mark_master.lua"
      ],
      "problemMatcher": []
    }
  ]
}
