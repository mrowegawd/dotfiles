(defvar image-lock "assets/lock.png")
(defvar image-logout "assets/logout.png")

(defwidget power []
  (box
    :class "power-menu"
    :halign "center"
    :valign "end"
    (box
      :orientation "h"
      :space-evenly true
      :hexpand false
      :vexpand false
      (button
        :class "icon power-button"
        :onclick "$HOME/.config/rofi/powermenu/poweroff" "")
      )
    )
  )
