(defwidget time []
  (eventbox
    :cursor "hand"
    :hexpand false
    :vexpand false
    :tooltip "${dateVar}"
    (box
      :orientation "v"
      :hexpand false
      :vexpand false
      :space-evenly false
      :class "clock"
      (button
        :class "clock"
        :onclick ""	"D:${time}")
      (button
        :class "clock"
        :onclick ""	"M:${calendar_month}")
    )
  )
)
