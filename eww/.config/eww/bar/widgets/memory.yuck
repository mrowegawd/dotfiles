(defwidget memory []
  (box
    :orientation "v"
    :space-evenly false
    :tooltip "RAM"
    :hexpand false
    :vexpand false
    (button
      :class "icon"
      :hexpand false
      :vexpand false
      :onclick "bar/scripts/openwindow.sh cpu &"
      (label :text "")
     )
     (button
      :class "texting"
      :hexpand false
      :vexpand false
      (label :text "${round(EWW_RAM.used_mem_perc, 0)}%")
     )
  )
)
