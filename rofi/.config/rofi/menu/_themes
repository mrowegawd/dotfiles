set_firefox() {
	IGET_BACKGROUND="$(xrdb -query | grep 'background' | awk '{print $NF}' | head -1)"

	IGET_CUS="$(xrdb -query | grep 'color8:' | awk '{print $NF}' | head -1)"
	IGET_RED="$(xrdb -query | grep 'color1:' | awk '{print $NF}' | head -1)"
	IGET_BLUE="$(xrdb -query | grep 'color4:' | awk '{print $NF}' | head -1)"
	IGET_CYAN="$(xrdb -query | grep 'color6:' | awk '{print $NF}' | head -1)"
	IGET_GREEN="$(xrdb -query | grep 'color2:' | awk '{print $NF}' | head -1)"
	IGET_YELLOW="$(xrdb -query | grep 'color3:' | awk '{print $NF}' | head -1)"

	FIREFOX_DEFAULT_PATH="$HOME/.mozilla/firefox/oehc9lj6.default-esr/chrome/components"
	# /home/mr00x/.mozilla/firefox/oehc9lj6.default-esr/chrome/components/ogx_root-personal.css

	sed -i -e "s/--fuchsia:.*/--fuchsia: $IGET_CUS; /" "$FIREFOX_DEFAULT_PATH/ogx_root-personal.css"
	sed -i -e "s/--blue:.*/--blue: $IGET_BLUE; /" "$FIREFOX_DEFAULT_PATH/ogx_root-personal.css"
	sed -i -e "s/--cyan:.*/--cyan: $IGET_CYAN; /" "$FIREFOX_DEFAULT_PATH/ogx_root-personal.css"
	sed -i -e "s/--green:.*/--green: $IGET_GREEN; /" "$FIREFOX_DEFAULT_PATH/ogx_root-personal.css"
	sed -i -e "s/--yellow:.*/--yellow: $IGET_YELLOW; /" "$FIREFOX_DEFAULT_PATH/ogx_root-personal.css"

	sed -i -e "s/--red:.*/--red: $IGET_RED; /" "$FIREFOX_DEFAULT_PATH/ogx_root-personal.css"

	sed -i -e "s/background-color:.*/background-color: $IGET_BACKGROUND !important;/g" "$FIREFOX_DEFAULT_PATH/ogx_tricks.css"

}

dir="$HOME/.config/rofi/menu"
theme="styles/big_center"
rofi_command="rofi -theme $dir/$theme"

(
	[[ ! -d $MISCXRDB_PATH ]] && dunstify "Warn " "Path: $MISCXRDB_PATH not found!" && exit 1
	_NAMETHEME=$(find "$MISCXRDB_PATH/xresource-theme" -type f -exec basename {} \; | sort | $rofi_command -dmenu -p "  ")
	[[ -z $_NAMETHEME ]] && exit 1

	STHEM="false"

	array=()
	while IFS= read -r -d $'\0'; do
		array+=("$REPLY")
	done < <(find "$HOME/.config/miscxrdb/xresource-theme" -type f -print0)

	for value in "${array[@]}"; do

		if [[ "$_NAMETHEME" == "$(basename "$value")" ]]; then
			STHEM="true"
		fi
	done

	if [[ $STHEM == "false" ]]; then
		dunstify "Load theme: $_NAMETHEME" "Not found, abort it"
		exit 1
	fi

	# # set new Xresources theme
	if [ -n "$_NAMETHEME" ]; then
		sed -i -e \
			"s/^#include \\([^ ]*xresource-theme[^ ]*\\)/#include \"\\.config\\/miscxrdb\\/xresource-theme\\/$_NAMETHEME\"/g" \
			"$DOTFILES_PATH/home/.Xresources"
		xrdb ~/.Xresources
		xrdb -merge ~/.Xresources
		sleep 1
	fi

	# reload paintree before updating themes
	~/.config/miscxrdb/exbin/paintree
	# shellcheck source=/dev/null
	. ~/.config/miscxrdb/exbin/get_var_paintee

	sleep 1

	set_rofi
	_NOTIF_ROFI="Rofi        ✅"

	set_dunst
	_NOTIF_DUNST="Dunst       ✅"

	set_tmux
	_NOTIF_TMUX="Tmux        ✅"

	set_btop
	_NOTIF_BTOP="Btop        ✅"

	set_zathura
	_NOTIF_ZATHURA="Zathura     ✅"

	set_vim "$_NAMETHEME"
	_NOTIF_VIM="Vim         ✅"

	set_terminal "$_NAMETHEME"
	_NOTIF_TERMINAL="Terminal    ✅"

	set_firefox "$_NAMETHEME"
	_NOTIF_FIREFOX="Firefox    ✅"

	case "$XDG_SESSION_DESKTOP" in
	"bspwm") wm_bspwm ;;
	"awesome") wm_awesome ;;
	esac

	dunstify -i ~/.config/miscxrdb/icons/todo-list.png "Load theme: $_NAMETHEME" "\n$_NOTIF_ROFI\n$_NOTIF_DUNST\n$_NOTIF_TMUX\n$_NOTIF_ZATHURA\n$_NOTIF_TERMINAL\n$_NOTIF_VIM\n$_NOTIF_BTOP\n$_NOTIF_FIREFOX"

)

