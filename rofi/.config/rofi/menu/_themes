# ─────────────────────────────────────────────────────────────────────────────
# setup: apply all themes
# ─────────────────────────────────────────────────────────────────────────────

setup() {
  local theme="$1"

  # Apply Xresources
  sed -i -e \
    "s/^#include \\([^ ]*xresource-theme[^ ]*\\)/#include \"\\.config\\/miscxrdb\\/xresource-theme\\/$theme\"/g" \
    "$DOTFILES_PATH/home/.Xresources"
  xrdb ~/.Xresources
  xrdb -merge ~/.Xresources

  set_rofi
  set_dunst
  set_tmux "$theme"
  set_btop
  set_eww
  set_vim "$theme"
  set_terminal "$theme"
  set_fzf
  set_yazi "$theme"
  set_lazygit
  set_lazydocker
  set_delta
  set_zshrc "$theme"
  set_shaders_color "$theme"
  set_kitty "$theme"
  set_eilmeldung

  sleep 1 && send_notify "Reload bspwm config.."

  "$HOME/.config/miscxrdb/exbin/fehbg" "$theme"

  local notifs=(
    "Btop" "Delta" "Dunst" "Eww" "FZF"
    "Kitty" "Rofi" "Terminal" "Tmux" "Vim"
    "Yazi" "Zshrc"
  )

  local message="Theme: $theme"
  for app in "${notifs[@]}"; do
    message+=$(printf "\n%-12s ✅" "$app")
  done

  send_notify "$message"
}

# ─────────────────────────────────────────────────────────────────────────────
# main
# ─────────────────────────────────────────────────────────────────────────────

main() {
  local dir="$HOME/.config/rofi/menu"
  local rofi_cmd="rofi -modi drun -theme $dir/styles/big_center -show drun"

  [[ ! -d "$MISCXRDB_PATH" ]] && {
    send_notify "Path: $MISCXRDB_PATH not found!"
    exit 1
  }

  local theme
  theme=$(find "$MISCXRDB_PATH/xresource-theme" -type f -exec basename {} \; | sort | $rofi_cmd -dmenu -p "  ")
  [[ -z "$theme" ]] && exit 1

  # Validate theme exists
  local found=false
  while IFS= read -r -d $'\0' f; do
    [[ "$(basename "$f")" == "$theme" ]] && found=true && break
  done < <(find "$HOME/.config/miscxrdb/xresource-theme" -type f -print0)

  if [[ "$found" == false ]]; then
    send_notify "Theme '$theme' not found, abort!"
    exit 1
  fi

  setup "$theme"
}

"$@"
