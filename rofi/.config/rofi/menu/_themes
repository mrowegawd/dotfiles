  }

  sed -i -e "s/^\$bg: .*/\$bg: $(theme_get eww_bg);/g" "$eww_scss"
  sed -i -e "s/^\$black: .*/\$black: $(theme_get eww_bg_darken);/g" "$eww_scss"
  sed -i -e "s/^\$altbg: .*/\$altbg: $(theme_get eww_bg_alt);/g" "$eww_scss"
  sed -i -e "s/^\$fg: .*/\$fg: $(theme_get eww_fg);/g" "$eww_scss"
  sed -i -e "s/^\$fg2: .*/\$fg2: $(theme_get eww_fg2);/g" "$eww_scss"
  sed -i -e "s/^\$red: .*/\$red: $(theme_get eww_red);/g" "$eww_scss"
  sed -i -e "s/^\$keyword: .*/\$keyword: $(theme_get eww_keyword);/g" "$eww_scss"
  sed -i -e "s/^\$magenta: .*/\$magenta: $(theme_get eww_icon_fg);/g" "$eww_scss"

  # Base xrdb colors
  sed -i -e "s/^\$altred: .*/\$altred: $GET_RED_ALT;/g" "$eww_scss"
  sed -i -e "s/^\$green: .*/\$green: $GET_GREEN;/g" "$eww_scss"
  sed -i -e "s/^\$altgreen: .*/\$altgreen: $GET_GREEN_ALT;/g" "$eww_scss"
  sed -i -e "s/^\$yellow: .*/\$yellow: $GET_YELLOW;/g" "$eww_scss"
  sed -i -e "s/^\$altyellow: .*/\$altyellow: $GET_YELLOW_ALT;/g" "$eww_scss"
  sed -i -e "s/^\$blue: .*/\$blue: $GET_BLUE;/g" "$eww_scss"
  sed -i -e "s/^\$altblue: .*/\$altblue: $GET_BLUE_ALT;/g" "$eww_scss"
  sed -i -e "s/^\$cyan: .*/\$cyan: $GET_CYAN;/g" "$eww_scss"
}

