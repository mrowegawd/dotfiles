#!/bin/bash

set -e -u

# ─────────────────────────────────────────────────────────────────────────────
# Paths
# ─────────────────────────────────────────────────────────────────────────────

DOTFILES_PATH="$HOME/moxconf/development/dotfiles"
MISCXRDB_PATH="$HOME/.config/miscxrdb"
MASTER_THEME_FILE=/tmp/master-colors-themes

# ─────────────────────────────────────────────────────────────────────────────
# Font
# ─────────────────────────────────────────────────────────────────────────────

NEW_FONTS="JetBrainsMono Nerd Font"
NEW_FONTS_SIZE=12

# ─────────────────────────────────────────────────────────────────────────────
# Colors from xrdb
# ─────────────────────────────────────────────────────────────────────────────

xrdb_get() { xrdb -query | grep -i "$1" | cut -d':' -f2 | head -1 | xargs; }

GET_FG=$(xrdb -query | grep -i foreground | cut -d':' -f2 | xargs)
GET_BG=$(xrdb -query | grep -i background | cut -d':' -f2 | xargs)

GET_RED=$(xrdb_get ".color1")
GET_RED_ALT=$(xrdb_get ".color9")
GET_GREEN=$(xrdb_get ".color2")
GET_GREEN_ALT=$(xrdb_get ".color10")
GET_YELLOW=$(xrdb_get ".color3")
GET_YELLOW_ALT=$(xrdb_get ".color11")
GET_BLUE=$(xrdb_get ".color4")
GET_BLUE_ALT=$(xrdb_get ".color12")
GET_MAGENTA=$(xrdb_get ".color5")
GET_CYAN=$(xrdb_get ".color6")
GET_WHITE=$(xrdb_get ".color7")

# ─────────────────────────────────────────────────────────────────────────────
# Extra color
# ─────────────────────────────────────────────────────────────────────────────

GET_COL_17="#333333"
if [[ -f "$MASTER_THEME_FILE" ]]; then
  GET_COL_17=$(grep -i color17 <"$MASTER_THEME_FILE" | cut -d':' -f2 | head -1 | xargs)
fi

# ─────────────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────────────

# Read a value from MASTER_THEME_FILE by key
theme_get() { grep -i "$1:" <"$MASTER_THEME_FILE" | cut -d':' -f2 | head -1 | xargs; }

# Replace a placeholder in a file: replace_in <file> <placeholder> <value>
replace_in() { sed -i -e "s/%%${2}%%/${3}/g" "$1"; }

# Replace a variable assignment: replace_var <file> <var> <value>
replace_var() { sed -i -e "s/^${2}=.*$/${2}=\"${3}\"/g" "$1"; }

lighten_color() {
  local hex_color="$1" factor="$2"
  [[ ${#hex_color} -ne 7 ]] && {
    echo "Error: HEX must be '#RRGGBB'."
    exit 1
  }
  local r g b
  r=$(printf "%d" 0x"${hex_color:1:2}")
  g=$(printf "%d" 0x"${hex_color:3:2}")
  b=$(printf "%d" 0x"${hex_color:5:2}")
  r=$((r + factor > 255 ? 255 : r + factor))
  g=$((g + factor > 255 ? 255 : g + factor))
  b=$((b + factor > 255 ? 255 : b + factor))
  printf "#%02x%02x%02x\n" "$r" "$g" "$b"
}

darken_color() {
  local hex_color="$1" factor="$2"
  [[ ${#hex_color} -ne 7 ]] && {
    echo "Error: HEX must be '#RRGGBB'."
    exit 1
  }
  local r g b
  r=$(printf "%d" 0x"${hex_color:1:2}")
  g=$(printf "%d" 0x"${hex_color:3:2}")
  b=$(printf "%d" 0x"${hex_color:5:2}")
  r=$((r - factor < 0 ? 0 : r - factor))
  g=$((g - factor < 0 ? 0 : g - factor))
  b=$((b - factor < 0 ? 0 : b - factor))
  printf "#%02x%02x%02x\n" "$r" "$g" "$b"
}

send_notify() {
  if command -v dunstify >/dev/null; then
    dunstify -i "$MISCXRDB_PATH/icons/bell.png" "Change Themes" "$1"
  else
    notify-send "Change Themes" "$1"
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# set_vim
# ─────────────────────────────────────────────────────────────────────────────

set_vim() {
  local nvim_config="$DOTFILES_PATH/nvim/.config/nvim/lua/r/config/init.lua"
  local colorscheme="$1"
  [[ "$colorscheme" == "base2tone-space-dark" ]] && colorscheme="base2tone_space_dark"
  sed -i -e "s/^local.colorscheme\s=.*/local colorscheme = \"$colorscheme\"/" "$nvim_config"
}

# ─────────────────────────────────────────────────────────────────────────────
# set_rofi
# ─────────────────────────────────────────────────────────────────────────────

set_rofi() {
  local rofi_path="$DOTFILES_PATH/rofi/.config/rofi"
  local rasi="$rofi_path/colors/nightly.rasi"

  [[ ! -d "$rofi_path" ]] && {
    send_notify "set_rofi: $rofi_path not found!"
    exit 1
  }

  cp "$rofi_path/colors/_nightly.rasi" "$rasi"

  replace_in "$rasi" "background" "$(theme_get rofi_background)"
  replace_in "$rasi" "background_alt" "$(theme_get rofi_background_alt)"
  replace_in "$rasi" "foreground" "$(theme_get rofi_foreground)"
  replace_in "$rasi" "keyword" "$(theme_get rofi_keyword)"
  replace_in "$rasi" "selected" "$(theme_get rofi_selected)"
  replace_in "$rasi" "selected_alt" "$(theme_get rofi_selected_alt)"
  replace_in "$rasi" "red" "$(theme_get rofi_red)"
  replace_in "$rasi" "green" "$(theme_get rofi_green)"
  replace_in "$rasi" "urgent" "$GET_MAGENTA"
  replace_in "$rasi" "blue" "$GET_BLUE"
  replace_in "$rasi" "yellow" "$GET_YELLOW"
  replace_in "$rasi" "border_alt" "$GET_YELLOW"
  replace_in "$rasi" "border" "$GET_BLUE"
}

# ─────────────────────────────────────────────────────────────────────────────
# set_dunst
# ─────────────────────────────────────────────────────────────────────────────

set_dunst() {
  local dunst_path="$DOTFILES_PATH/dunst/.config/dunst"
  local dunstrc="$dunst_path/dunstrc"

  [[ ! -d "$dunst_path" ]] && {
    send_notify "set_dunst: $dunst_path not found!"
    exit 1
  }

  cat "$dunst_path/dunst-config" "$dunst_path/dunst-theme" >"$dunstrc"

  # Title
  replace_in "$dunstrc" "header_title_fg" "$(theme_get dunst_normal_title_fg)"

  # Low
  replace_in "$dunstrc" "low_bg" "$(theme_get dunst_low_bg)"
  replace_in "$dunstrc" "low_fg" "$(theme_get dunst_low_fg)"
  replace_in "$dunstrc" "low_frame_fg" "$(theme_get dunst_low_frame)"

  # Normal
  replace_in "$dunstrc" "normal_bg" "$(theme_get dunst_normal_bg)"
  replace_in "$dunstrc" "normal_fg" "$(theme_get dunst_normal_fg)"
  replace_in "$dunstrc" "normal_frame_fg" "$(theme_get dunst_normal_frame)"

  # Critical
  replace_in "$dunstrc" "critical_fg" "$(theme_get dunst_critical_fg)"
  replace_in "$dunstrc" "critical_bg" "$(theme_get dunst_critical_bg)"
  replace_in "$dunstrc" "critical_frame_fg" "$(theme_get dunst_critical_frame)"

  # General
  replace_in "$dunstrc" "background" "$(theme_get dunst_bg)"
  replace_in "$dunstrc" "foreground" "$(theme_get dunst_fg)"
  replace_in "$dunstrc" "color_border" "$(theme_get dunst_border)"
  replace_in "$dunstrc" "frame_border" "$GET_RED"
  replace_in "$dunstrc" "frame_color" "$GET_BLUE"

  # Font
  replace_in "$dunstrc" "font_style" "$NEW_FONTS"
  replace_in "$dunstrc" "font_size" "$NEW_FONTS_SIZE"

  "$HOME/.config/dunst/rundust.sh" >/dev/null
}

# ─────────────────────────────────────────────────────────────────────────────
# set_tmux
# ─────────────────────────────────────────────────────────────────────────────

set_tmux() {
  local tmux_themes="$DOTFILES_PATH/tmuxconfig/.config/tmuxconfig/themes/tmux-snapshot"

  if [[ ! -f "$tmux_themes" ]]; then
    send_notify "set_tmux: $tmux_themes not found!"
    return
  fi

  sleep 1

  # General
  replace_var "$tmux_themes" "TMUX_FG" "$(theme_get tmux_fg)"
  replace_var "$tmux_themes" "TMUX_BG" "$(theme_get tmux_bg)"
  replace_var "$tmux_themes" "FM_BG" "$(theme_get tmux_fm_bg)"
  replace_var "$tmux_themes" "TMUX_KEYWORD" "$(theme_get tmux_keyword)"

  # Tab
  replace_var "$tmux_themes" "TAB_ACTIVE_FG" "$(theme_get tmux_tab_active_fg)"
  replace_var "$tmux_themes" "TAB_ACTIVE_BG" "$(theme_get tmux_tab_active_bg)"

  # Border
  replace_var "$tmux_themes" "BORDER_ACTIVE" "$(theme_get tmux_border_active)"
  replace_var "$tmux_themes" "BORDER_INACTIVE" "$(theme_get tmux_border_inactive)"
  replace_var "$tmux_themes" "BORDER_INACTIVE_STATUS_FG" "$(theme_get tmux_border_inactive_status_fg)"

  # Session
  replace_var "$tmux_themes" "SESSION_BG" "$(theme_get tmux_session_bg)"
  replace_var "$tmux_themes" "SESSION_FG" "$(theme_get tmux_session_fg)"

  # Statusline
  replace_var "$tmux_themes" "STATUSLINE_FG" "$(theme_get tmux_statusline_fg)"
  replace_var "$tmux_themes" "STATUSLINE_BG" "$(theme_get tmux_statusline_bg)"
  replace_var "$tmux_themes" "STATUSLINE_BG_MESSAGE" "$(theme_get tmux_message_bg)"
  replace_var "$tmux_themes" "TMUX_VISUAL_BG" "$(theme_get tmux_visual_bg)"

  # Base colors
  replace_var "$tmux_themes" "RED" "$GET_RED"
  replace_var "$tmux_themes" "BLUE" "$GET_BLUE"
  replace_var "$tmux_themes" "WHITE" "$GET_WHITE"
  replace_var "$tmux_themes" "GREEN" "$GET_GREEN"
}

# ─────────────────────────────────────────────────────────────────────────────
# set_kitty
# ─────────────────────────────────────────────────────────────────────────────

set_kitty() {
  local kitty_theme="$DOTFILES_PATH/kitty/.config/kitty/colors/$1.conf"

  if [[ ! -f "$kitty_theme" ]]; then
    send_notify "set_kitty: $kitty_theme not found!"
    return
  fi

  sleep 1

  # Tab
  sed -i -e "s/^active_tab_foreground.*$/active_tab_foreground   $(theme_get kitty_tab_active_fg)/g" "$kitty_theme"
  sed -i -e "s/^active_tab_background.*$/active_tab_background   $(theme_get kitty_tab_active_bg)/g" "$kitty_theme"
  sed -i -e "s/^inactive_tab_foreground.*$/inactive_tab_foreground $(theme_get kitty_tab_inactive_fg)/g" "$kitty_theme"
  sed -i -e "s/^inactive_tab_background.*$/inactive_tab_background $(theme_get kitty_tab_inactive_bg)/g" "$kitty_theme"
  sed -i -e "s/^tab_bar_background.*$/tab_bar_background      $(theme_get kitty_tab_bar_bg)/g" "$kitty_theme"

  # Border
  sed -i -e "s/^active_border_color\s.*$/active_border_color   $(theme_get kitty_border_active)/g" "$kitty_theme"
  sed -i -e "s/^inactive_border_color\s.*$/inactive_border_color $(theme_get kitty_border_inactive)/g" "$kitty_theme"
}

# ─────────────────────────────────────────────────────────────────────────────
# set_delta
# ─────────────────────────────────────────────────────────────────────────────

set_delta() {
  local delta_path="$HOME/.config/delta/themes"

  [[ ! -f "$delta_path" ]] && {
    send_notify "set_delta: $delta_path not found!"
    exit 1
  }

  # Hunk header
  sed -i -e "s/^hunk-header-style.*/hunk-header-style = \"$(theme_get delta_hunk_header_fg)\" bold \"$(theme_get delta_hunk_header_bg)\"/g" "$delta_path"

  # Line numbers
  sed -i -e "s/^line-numbers-zero-style.*/line-numbers-zero-style = \"$(theme_get delta_line_number_fg)\"/g" "$delta_path"

  # Plus (added)
  sed -i -e "s/^plus-style.*/plus-style = \"$(theme_get delta_hunk_plus_fg)\" bold \"$(theme_get delta_hunk_plus_bg)\"/g" "$delta_path"
  sed -i -e "s/^plus-emph-style.*/plus-emph-style = \"$(theme_get delta_hunk_emp_plus_fg)\" bold \"$(theme_get delta_hunk_emp_plus_bg)\"/g" "$delta_path"

  # Minus (deleted)
  sed -i -e "s/^minus-style.*/minus-style = \"$(theme_get delta_hunk_minus_fg)\" bold \"$(theme_get delta_hunk_minus_bg)\"/g" "$delta_path"
}

# ─────────────────────────────────────────────────────────────────────────────
# set_zathura
# ─────────────────────────────────────────────────────────────────────────────

set_zathura() {
  local zathura_path="$DOTFILES_PATH/zathura/.config/zathura"
  local zathurarc="$zathura_path/zathurarc"

  [[ ! -d "$zathura_path" ]] && {
    send_notify "set_zathura: $zathura_path not found!"
    exit 1
  }

  sed -i -e "s/^set default-bg.*/set default-bg \"$GET_BG\"/g" "$zathurarc"
  sed -i -e "s/^set default-fg.*/set default-fg \"$GET_FG\"/g" "$zathurarc"
  sed -i -e "s/^set notification-bg.*/set notification-bg \"$GET_BG\"/g" "$zathurarc"
  sed -i -e "s/^set notification-fg.*/set notification-fg \"$GET_FG\"/g" "$zathurarc"
  sed -i -e "s/^set highlight-color.*/set highlight-color \"$GET_RED\"/g" "$zathurarc"
  sed -i -e 's/^set highlight-fg.*/set highlight-fg "#0e0807"/g' "$zathurarc"
  sed -i -e "s/^set inputbar-bg.*/set inputbar-bg \"$GET_GREEN\"/g" "$zathurarc"
  sed -i -e "s/^set recolor-lightcolor.*/set recolor-lightcolor \"$GET_BG\"/g" "$zathurarc"
}

# ─────────────────────────────────────────────────────────────────────────────
# set_terminal
# ─────────────────────────────────────────────────────────────────────────────

set_terminal() {
  # Ghostty
  local ghostty_theme="$HOME/.config/ghostty/themes/$1"
  if [[ -f "$ghostty_theme" ]]; then
    sed -i -e "s/^theme\s=.*/theme = $1/g" "$HOME/.config/ghostty/config"
  else
    dunstify "theme ghostty [-]"
  fi

  # Kitty
  local kitty_theme="$HOME/.config/kitty/colors/$1.conf"
  if [[ -f "$kitty_theme" ]]; then
    sed -i -e "s/^include\s~\\/.config\\/kitty\\/colors.*/include ~\\/.config\\/kitty\\/colors\\/$1.conf/g" \
      "$HOME/.config/kitty/kitty.conf"
  else
    dunstify "theme kitty [-]"
  fi
}

