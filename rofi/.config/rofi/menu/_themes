set_firefox() {
  local firefox_path="$HOME/.mozilla/firefox/oehc9lj6.default-esr/chrome/components"
  local css_personal="$firefox_path/ogx_root-personal.css"
  local css_tricks="$firefox_path/ogx_tricks.css"

  if [[ ! -d "$firefox_path" ]]; then
    send_notify "set_firefox: $firefox_path not found!"
    return
  fi

  local color8
  color8="$(xrdb -query | grep 'color8:' | awk '{print $NF}' | head -1)"

  sed -i -e "s/--fuchsia:.*/--fuchsia: $color8; /" "$css_personal"
  sed -i -e "s/--blue:.*/--blue: $GET_BLUE; /" "$css_personal"
  sed -i -e "s/--cyan:.*/--cyan: $GET_CYAN; /" "$css_personal"
  sed -i -e "s/--green:.*/--green: $GET_GREEN; /" "$css_personal"
  sed -i -e "s/--yellow:.*/--yellow: $GET_YELLOW; /" "$css_personal"
  sed -i -e "s/--red:.*/--red: $GET_RED; /" "$css_personal"
  sed -i -e "s/background-color:.*/background-color: $GET_BG !important;/g" "$css_tricks"
}

