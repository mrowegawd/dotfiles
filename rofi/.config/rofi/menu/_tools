#!/bin/bash

LC_TIME=id_ID.UTF-8

dir="$HOME/.config/rofi/menu"
theme="styles/menuleft"
rofi_command="rofi -theme $dir/$theme"
MENULIST_PATH="Calendar\nFile manager [UI]\nKeyboard\nPomodoro\nRecord Video Fullscreen\nRecord Video Rectangle Blur\nRecord Gif Rectangle\nRecord Video Rectangle\nRecord Gif\nStop Record\nScreenshot\nDrawing\nSyncUpdate\nNeovide"

PATH_VIDEOS="$HOME/Downloads/screenshot/videos"
mkdir -p "$PATH_VIDEOS"

TIMESTAMP="$(date '+%y%m%d-%H-%M-%S')"
FILE_RECORDING_BAK="$PATH_VIDEOS/ffmpeg-bak-${TIMESTAMP}.mp4"
FILE_NAME_RECORD="ffmpeg-${TIMESTAMP}.mp4"
FILE_RECORDING="$PATH_VIDEOS/$FILE_NAME_RECORD"

PID_FILE="/tmp/ffmpeg-record.pid"
INFO_FILE="/tmp/ffmpeg-record.info"

