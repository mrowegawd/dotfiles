record_x11() {
  local geometry="$1"
  local offset="$2"
  local outfile="$3"
  local with_audio="${4:-yes}"

  local audio_args=()
  if [[ "$with_audio" == "yes" ]]; then
    audio_args=(-f alsa -ac 2 -i default)
  fi

  ffmpeg \
    -f x11grab \
    -framerate 30 \
    -video_size "$geometry" \
    -i "${DISPLAY}${offset}" \
    "${audio_args[@]}" \
    -vf "crop=trunc(iw/2)*2:trunc(ih/2)*2" \
    -c:v libx264 \
    -preset ultrafast \
    -crf 18 \
    -pix_fmt yuv420p \
    -threads 0 \
    -y "$outfile" &

  echo $! >"$PID_FILE"
}

encode_for_telegram() {
  local input="$1"
  local output="$2"
  local vf="${3:-scale=min(1280\,iw):-2:flags=lanczos}"

  ffmpeg -i "$input" \
    -c:v libx264 \
    -crf 28 \
    -preset fast \
    -maxrate 2M \
    -bufsize 4M \
    -vf "$vf" \
    -pix_fmt yuv420p \
    -c:a aac \
    -b:a 96k \
    -movflags +faststart \
    -y "$output"
}

make_gif_from_video() {
  local input="$1"
  local output="$2"
  local fps="${3:-15}"
  local width="${4:-800}"
  local palette="/tmp/gif_palette_$$.png"

  ffmpeg -i "$input" \
    -vf "fps=${fps},scale=${width}:-1:flags=lanczos,palettegen=stats_mode=diff" \
    -y "$palette"

  ffmpeg -i "$input" -i "$palette" \
    -lavfi "fps=${fps},scale=${width}:-1:flags=lanczos [x]; [x][1:v] paletteuse=dither=bayer:bayer_scale=5:diff_mode=rectangle" \
    -y "$output"

  rm -f "$palette"
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ RECORD VIDEO                                             ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

run_ffmpeg_record_fullscreen() {
  if is_recording; then
    send_notify "Already recording! Stop first."
    return
  fi

  local geometry
  geometry=$(xwininfo -root | awk '/geometry/ {gsub("+.*",""); print $2}')
  [[ ! $geometry =~ ^[0-9]+x[0-9]+$ ]] && return

  echo "video|$FILE_RECORDING_BAK|$FILE_RECORDING|$FILE_NAME_RECORD|" >"$INFO_FILE"
  send_notify "Start Recording (fullscreen).. \nSelect 'Stop Record' to finish"
  record_x11 "$geometry" "" "$FILE_RECORDING_BAK"
}

run_ffmpeg_record_with_rectangle() {
  if is_recording; then
    send_notify "Already recording! Stop first."
    return
  fi

  local slop_info geometry offset
  slop_info=$(slop -D -f "%wx%h+%x+%y") || return

  geometry=$(echo "$slop_info" | awk -F "+" '{print $1}')
  offset="+$(echo "$slop_info" | awk -F "+" '{print $2"+"$3}')"

  [[ ! $geometry =~ ^[0-9]+x[0-9]+$ ]] && return

  echo "video|$FILE_RECORDING_BAK|$FILE_RECORDING|$FILE_NAME_RECORD|" >"$INFO_FILE"
  send_notify "Start Recording (rectangle).. \nSelect 'Stop Record' to finish"
  record_x11 "$geometry" "$offset" "$FILE_RECORDING_BAK"
}

run_ffmpeg_record_with_rectangle_blurred() {
  if is_recording; then
    send_notify "Already recording! Stop first."
    return
  fi

  local slop_info slop_blur geometry offset blur_x blur_y blur_w blur_h
  slop_info=$(slop -D -f "%wx%h+%x+%y") || return
  slop_blur=$(slop -D -f "%x %y %w %h") || return

  geometry=$(echo "$slop_info" | awk -F "+" '{print $1}')
  offset="+$(echo "$slop_info" | awk -F "+" '{print $2"+"$3}')"
  read -r blur_x blur_y blur_w blur_h <<<"$slop_blur"

  [[ ! $geometry =~ ^[0-9]+x[0-9]+$ ]] && return

  local blur_vf="split[main][tmp];[tmp]crop=${blur_w}:${blur_h}:${blur_x}:${blur_y},boxblur=luma_radius=10:luma_power=2[blurred];[main][blurred]overlay=${blur_x}:${blur_y}"
  echo "video|$FILE_RECORDING_BAK|$FILE_RECORDING|$FILE_NAME_RECORD|$blur_vf" >"$INFO_FILE"
  send_notify "Start Recording (blur).. \nSelect 'Stop Record' to finish"
  record_x11 "$geometry" "$offset" "$FILE_RECORDING_BAK"
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ RECORD GIF                                               ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

_start_gif_record() {
  local geometry="$1"
  local offset="$2"

  local ts output_mkv output_gif output_mp4
  ts="$TIMESTAMP"
  output_mkv="$PATH_VIDEOS/${ts}.mkv"
  output_gif="$PATH_VIDEOS/${ts}.gif"
  output_mp4="$PATH_VIDEOS/${ts}-tg.mp4"

  echo "gif|$output_mkv|$output_gif|$output_mp4" >"$INFO_FILE"
  send_notify "Record gif start.. \nSelect 'Stop Record' to finish"
  record_x11 "$geometry" "$offset" "$output_mkv" "no"
}

run_simplegif_with_rectangle() {
  if is_recording; then
    send_notify "Already recording! Stop first."
    return
  fi

  local slop_info geometry offset
  slop_info=$(slop -D -f "%wx%h+%x+%y") || return

  geometry=$(echo "$slop_info" | awk -F "+" '{print $1}')
  offset="+$(echo "$slop_info" | awk -F "+" '{print $2"+"$3}')"

  [[ ! $geometry =~ ^[0-9]+x[0-9]+$ ]] && return
  _start_gif_record "$geometry" "$offset"
}

run_simplegif() {
  if is_recording; then
    send_notify "Already recording! Stop first."
    return
  fi

  local slop_info geometry offset
  slop_info=$(slop -D -f "%wx%h+%x+%y") || return

  geometry=$(echo "$slop_info" | awk -F "+" '{print $1}')
  offset="+$(echo "$slop_info" | awk -F "+" '{print $2"+"$3}')"

  [[ ! $geometry =~ ^[0-9]+x[0-9]+$ ]] && return
  _start_gif_record "$geometry" "$offset"
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ STOP                                                     ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

run_ffmpeg_stop() {
  if ! is_recording; then
    send_notify "No active recording found"
    return
  fi

  local pid
  pid=$(cat "$PID_FILE")

  kill -INT "$pid" 2>/dev/null

  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    sleep 0.5
    ((i++))
    if [[ $i -gt 20 ]]; then
      kill -9 "$pid" 2>/dev/null
      break
    fi
  done

  rm -f "$PID_FILE"

  if [[ ! -f "$INFO_FILE" ]]; then
    send_notify "Recording stopped (no info file)"
    return
  fi

  local type field1 field2 field3 field4
  IFS='|' read -r type field1 field2 field3 field4 <"$INFO_FILE"
  rm -f "$INFO_FILE"

  if [[ "$type" == "gif" ]]; then
    local output_mkv="$field1"
    local output_gif="$field2"
    local output_mp4="$field3"

    if [[ -f "$output_mkv" ]]; then
      send_notify "Processing gif..."
      make_gif_from_video "$output_mkv" "$output_gif" 15 800
      encode_for_telegram "$output_mkv" "$output_mp4"
      rm -f "$output_mkv"
      send_notify "Saved gif: $(basename "$output_gif") ($(du -sh "$output_gif" | cut -f1))\nmp4: $(basename "$output_mp4") ($(du -sh "$output_mp4" | cut -f1))" 5000
    fi
  else
    local bak="$field1"
    local final="$field2"
    local name="$field3"
    local vf="$field4"

    if [[ -f "$bak" ]]; then
      send_notify "Processing video for telegram..."
      if [[ -n "$vf" ]]; then
        encode_for_telegram "$bak" "$final" "$vf"
      else
        encode_for_telegram "$bak" "$final"
      fi
      rm -f "$bak"
      send_notify "Saved: $name ($(du -sh "$final" | cut -f1))"
    fi
  fi
}

