# ╎ UTILS                                                    ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

send_notify() {
  local time=${2:-1000}
  COL_MSG_SUCCSS="$(xrdb -query | grep "color3" | head -n 1 | cut -d":" -f2 | xargs)"

  if command -v dunstify >/dev/null; then
    dunstify -t "$time" -i "$HOME/.config/miscxrdb/icons/rec-button.png" \
      "RECORDING" "<b><span foreground='$COL_MSG_SUCCSS'>$1</span></b>"
  else
    notify-send "RECORDING" "$1"
  fi
}

is_recording() {
  [[ -f "$PID_FILE" ]] || return 1
  local pid
  pid=$(cat "$PID_FILE")
  [[ -n "$pid" ]] && [[ -d "/proc/$pid" ]]
}

