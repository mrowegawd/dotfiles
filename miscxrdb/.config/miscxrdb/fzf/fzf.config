function _gen_fzf_default_opts() {

    # --files: List files that would be searched but do not search
    # --no-ignore: Do not respect .gitignore, etc...
    # --hidden: Search hidden files and folders
    export FZF_DEFAULT_COMMAND='rg --files --no-ignore-vcs --hidden --smart-case'

    # export FZF_DEFAULT_COMMAND='rg --no-heading --hidden --follow --no-ignore-vcs --smart-case '
        export FZF_CTRL_T_COMMAND='fd --hidden --follow --exclude .git'

    export FZF_DEFAULT_OPTS='
        --bind ctrl-a:toggle-all,ctrl-l:clear-query,ctrl-d:preview-down,ctrl-u:preview-up,ctrl-n:down,ctrl-p:up,ctrl-g:top,F4:toggle-preview,ctrl-f:half-page-down,ctrl-b:half-page-up
    --color=bg+:#3c3c3c,fg+:#ffffff,hl+:#ff573e,gutter:#222222,pointer:#a9b665
    --color=bg:,fg:#666666,hl:#7d241a,border:#383838 --height=65%
        --preview "bat --style=plain --color=always {}" --preview-window right:50%:hidden:wrap --border --reverse
    --cycle --prompt="> "'
}

_gen_fzf_default_opts
