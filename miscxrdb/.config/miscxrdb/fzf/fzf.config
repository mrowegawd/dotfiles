_gen_fzf_default_opts() {

  # rule:respect .gitignore file
  # export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --no-ignore-vcs -g "!{node_modules,.git,__pycache__,.pytest_cache}"'

      export FZF_DEFAULT_COMMAND='rg --files --no-ignore-vcs --hidden'

  export FZF_DEFAULT_OPTS='
  --bind ctrl-a:toggle-all,ctrl-l:clear-query,ctrl-d:preview-down,ctrl-u:preview-up,ctrl-n:down,ctrl-p:up,ctrl-g:top,F4:toggle-preview
  --color=bg:#151520,fg:,hl:#915364 --height=40%
  --color=bg+:#30313e,fg+:#CDD6F4,hl+:#915364,gutter:#1e1e2e,pointer:#A6E3A1
  --preview "echo {}" --preview-window down:4:hidden:wrap --border
  --cycle --prompt="> "'

  # export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window down:4:hidden:wrap --bind '?:toggle-preview' --bind 'ctrl-y:execute-silent(echo -n {2..} | pbcopy)+abort' --header 'Press CTRL-Y to copy command into clipboard' --border"
  # --ansi --preview-window "right:60%" --preview "bat --color=always --style=header,grid --line-range :300 {} "
  #--color=spinner:#F38BA8,marker:#F38BA8,prompt:#F5C2E7,header:#F38BA8,info:#F5C2E7,pointer:#A6E3A1

  # #####################
  # --exact       match exact words( dont fuzzy match foot to fzozo )
  # --cycle       Up/Down wraps to top/bottom of results
  # --reverse     Input on top, results below
  # --margin=0.4  some margin differentiate fzf appearance
  #
  # Custom key bindings
  # export FZF_DEFAULT_OPTS=$ FZF_DEFAULT_OPTS' --bind=ctrl-n:down,ctrl-e:up,ctrl-f:page-down,ctrl-b:page-up'
  # #####################

  # Use tmux panes for fzf to avoid the shell output getting pushed around.
  # export FZF_TMUX=0
  # export FZF_TMUX=1
  # export FZF_TMUX_OPTS="-p 80%"


}
_gen_fzf_default_opts
