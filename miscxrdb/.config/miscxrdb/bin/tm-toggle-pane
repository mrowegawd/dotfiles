#!/bin/bash

LAYOUT_SIDE="left"

FIXED_HEIGHT_BELOW_PANE=15
FIXED_HEIGHT_MAIN_PANE=50

ORIGIN_SESSION=$(tmux display-message -p '#S')
ORIGIN_WINDOW=$(tmux display-message -p '#I')
ORIGIN_PANE=$(tmux display-message -p '#{pane_id}')
ORIGIN_TARGET="${ORIGIN_SESSION}:${ORIGIN_WINDOW}"

tmux_resize_pane_to_20percent() {
  local window_width
  window_width=$(tmux display -p -t "$ORIGIN_TARGET" "#{window_width}")
  echo $((window_width * 18 / 100))
}

new_fixed_resize_value=$(tmux_resize_pane_to_20percent)
FIXED_RESIZE_TMUX_LEFT_OR_RIGHT=$new_fixed_resize_value

FILE_MANAGER="$TERM_FILEMANAGER"

# ─[ SETTINGS COLOR ]───────────────────────────────────────────────────
COLOR_CLOCK=$(xrdb -query | grep 'color16:' | awk '{print $NF}')
COL_BORDER_FG=$(xrdb -query | grep -i .color16 | cut -d':' -f2 | head -1 | xargs)
COL_BORDER_BG=$(xrdb -query | grep -i background | cut -d':' -f2 | xargs)
FM_BG="#3a3a3a"
TMUX_BG="#1f1f1f"
TMUX_SNAPSHOT_PATH="$HOME/.config/tmuxconfig/themes/tmux-snapshot"
if [ -f "$TMUX_SNAPSHOT_PATH" ]; then
  COL_BORDER_BG=$(grep -i TMUX_BG <"$TMUX_SNAPSHOT_PATH" | head -1 | cut -d"=" -f2 | sed s/\"//g)
  COLOR_CLOCK=$(grep -i SESSION_FG <"$TMUX_SNAPSHOT_PATH" | head -1 | cut -d"=" -f2 | sed s/\"//g)
  FM_BG=$(grep -i FM_BG <"$TMUX_SNAPSHOT_PATH" | head -1 | cut -d"=" -f2 | sed s/\"//g)
  TMUX_BG=$(grep -i TMUX_BG <"$TMUX_SNAPSHOT_PATH" | head -1 | cut -d"=" -f2 | sed s/\"//g)
fi

GET_TOTAL_ACTIVE_PANES=$(tmux list-panes -t "$ORIGIN_TARGET" | wc -l)
PATH_PANE_COLLECT_JSON="/tmp/tmux-main-layout-workspaces.json"

CURRENT_SESSION=""
WINDOW_ID=""
MAIN_PANE_ID=""
FILE_MANAGER_PANE_ID=""
TOGGLE_TERM_PANE_ID=""
CLOCK_PANE_ID=""
CURRENT_CWD=""

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ SESSION HELPER                                           ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

session_exists() {
  tmux has-session -t "=$1" 2>/dev/null
}

not_in_tmux() {
  [[ -z "$TMUX" ]]
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ UTILS                                                    ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

_check_pane_is() {
  local pane_id="$1"
  local target_cmd="$2"
  local current_cmd
  current_cmd=$(tmux display-message -p -t "$pane_id" "#{pane_current_command}" 2>/dev/null | tr -d '\n')
  [[ "$current_cmd" == "$target_cmd" ]]
}

_send_keys_to_pane() {
  local pane="$1"
  local cmd="$2"
  tmux send-keys -t "$pane" "$cmd" Enter
}

__is_pane_id_exists() {
  local pane_id="$1"
  [[ -z "$pane_id" ]] && return 1
  tmux list-panes -a -F "#{pane_id}" 2>/dev/null | grep -Fxq "$pane_id"
}

__send_notify() {
  local type="$1"
  local message="${2:-}"
  local header="🔄 Tmux WORKSPCHelper"

  case "$type" in
  workspaces_notify)
    dunstify -i view-refresh -t 2000 "$header" "$message"
    ;;
  workspaces_notify_warn)
    dunstify -i view-refresh -u critical -t 5000 "$header" "$message"
    ;;
  open_in_nvim)
    dunstify -i text-editor -u normal -t 3000 "󰢱 Open In Nvim" "$message"
    ;;
  *)
    dunstify "$header" "$message"
    ;;
  esac
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ NAVIGATION                                               ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

_go_left() { tmux select-pane -L; }
_go_right() { tmux select-pane -R; }
_go_select_pane_with_id() { tmux select-pane -t "$1"; }
_go_last_pane() { tmux last-pane; }

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ JSON HELPER                                              ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

__init_json_file() {
  local current_session="$CURRENT_SESSION"
  local window_id="$WINDOW_ID"
  local main_pane_id="$MAIN_PANE_ID"
  local cwd="$CURRENT_CWD"
  local json_file="$PATH_PANE_COLLECT_JSON"

  [[ ! -f "$json_file" ]] && touch "$json_file"

  if [[ ! -s "$json_file" ]]; then
    cat >"$json_file" <<EOF
{
  "$current_session": {
    "$window_id": {
      "main_pane_id": "$main_pane_id",
      "file_manager_pane_id": "",
      "toggle_term_pane_id": "",
      "clock_pane_id": "",
      "cwd": "$cwd",
      "file_manager_layout": "$LAYOUT_SIDE"
    }
  }
}
EOF
  fi
}

__update_session_obj() {
  local session_name="$1"
  local current_pane="$2"
  local window_id="$3"
  local cwd="$4"
  local json_file="$PATH_PANE_COLLECT_JSON"

  jq --arg name "$session_name" \
    --arg current_pane "$current_pane" \
    --arg window_id "$window_id" \
    --arg cwd "$cwd" \
    --arg left "$LAYOUT_SIDE" \
    '. + {($name): {($window_id): {
      "main_pane_id": $current_pane,
      "file_manager_pane_id": "",
      "toggle_term_pane_id": "",
      "cwd": $cwd,
      "file_manager_layout": $left
    }}}' "$json_file" >tmp.json && mv tmp.json "$json_file"
}

__update_window_obj() {
  local session_name="$1"
  local current_pane="$2"
  local window_id="$3"
  local cwd="$4"
  local json_file="$PATH_PANE_COLLECT_JSON"

  jq --arg session_name "$session_name" \
    --arg window_id "$window_id" \
    --arg current_pane "$current_pane" \
    --arg cwd "$cwd" \
    --arg left "$LAYOUT_SIDE" \
    '.[$session_name][$window_id] = {
      "main_pane_id": $current_pane,
      "file_manager_pane_id": "",
      "toggle_term_pane_id": "",
      "cwd": $cwd,
      "file_manager_layout": $left
    }' "$json_file" >tmp.json && mv tmp.json "$json_file"
  # Bug fix: "$left" sebelumnya tidak expand
}

__remove_data_obj() {
  local session_name="$1"
  local window_id="$2"
  local json_file="$PATH_PANE_COLLECT_JSON"

  jq --arg session_name "$session_name" --arg window_id "$window_id" \
    '.[$session_name][$window_id] = {}' "$json_file" >tmp.json && mv tmp.json "$json_file"
}

__update_field_session_obj() {
  local session_name="$1"
  local window_id="$2"
  local pane_id="$3"
  local field="$4"

  if [[ -z "$session_name" || -z "$pane_id" || -z "$field" ]]; then
    __send_notify "workspaces_notify_warn" "Missing arguments for JSON update"
    return 1
  fi

  jq --arg session_name "$session_name" \
    --arg window_id "$window_id" \
    --arg field "$field" \
    --arg pane_id "$pane_id" \
    '.[$session_name][$window_id][$field] = $pane_id' \
    "$PATH_PANE_COLLECT_JSON" >tmp.json && mv tmp.json "$PATH_PANE_COLLECT_JSON"
}

__update_main_pane_id() {
  local session_name="$1" window_id="$2" pane_id="$3"
  [[ -z "$pane_id" ]] && {
    __send_notify "workspaces_notify_warn" "⚠️  Main pane ID is empty!"
    return
  }
  __update_field_session_obj "$session_name" "$window_id" "$pane_id" "main_pane_id"
}

__update_pane_file_manager_id() {
  local session_name="$1" window_id="$2" pane_id="$3"
  [[ -z "$pane_id" ]] && {
    __send_notify "workspaces_notify" "⚠️  File manager pane ID is empty!"
    return
  }
  __update_field_session_obj "$session_name" "$window_id" "$pane_id" "file_manager_pane_id"
}

__update_pane_toggle_term() {
  local session_name="$1" window_id="$2" pane_id="$3"
  [[ -z "$pane_id" ]] && {
    __send_notify "workspaces_notify" "⚠️  Toggle term pane ID is empty!"
    return
  }
  __update_field_session_obj "$session_name" "$window_id" "$pane_id" "toggle_term_pane_id"
}

__update_pane_clock_id() {
  local session_name="$1" window_id="$2" pane_id="$3"
  [[ -z "$pane_id" ]] && {
    __send_notify "workspaces_notify" "⚠️  Clock pane ID is empty!"
    return
  }
  __update_field_session_obj "$session_name" "$window_id" "$pane_id" "clock_pane_id"
}

__is_current_session_exits_from_json() {
  local session_name="$1"
  jq -e --arg s "$session_name" '.[$s]' "$PATH_PANE_COLLECT_JSON" >/dev/null 2>&1
}

__is_current_window_id_session_exits_from_json() {
  local session_name="$1"
  local window_name="$2"
  jq -e --arg s "$session_name" --arg w "$window_name" '.[$s] | has($w)' \
    "$PATH_PANE_COLLECT_JSON" >/dev/null 2>&1
}

__extract_id_from_json() {
  local session_name="$1"
  local window_name="$2"
  local field_name="$3"

  [[ ! -f "$PATH_PANE_COLLECT_JSON" ]] && return 1

  jq -r \
    --arg s "$session_name" \
    --arg w "$window_name" \
    --arg f "$field_name" \
    '.[$s][$w][$f] // empty' \
    "$PATH_PANE_COLLECT_JSON"
}

__get_main_pane_id() { __extract_id_from_json "$1" "$2" "main_pane_id"; }
__get_file_manager_pane_id() { __extract_id_from_json "$1" "$2" "file_manager_pane_id"; }
__get_toggle_term_id() { __extract_id_from_json "$1" "$2" "toggle_term_pane_id"; }
__get_clock_pane_id() { __extract_id_from_json "$1" "$2" "clock_pane_id"; }

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ PANE SPLIT HELPERS                                       ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

open_vsplit() {
  local pane_count
  pane_count=$(tmux list-panes -t "$ORIGIN_TARGET" | wc -l)

  if [[ "$pane_count" -gt 1 ]]; then
    tmux split-window -h -t "$ORIGIN_TARGET" -c '#{pane_current_path}'
  else
    tmux split-window -hl 80 -t "$ORIGIN_TARGET" -c '#{pane_current_path}'
  fi
}

open_split() {
  tmux split-window -v -l 20 -t "$ORIGIN_TARGET" -c '#{pane_current_path}'
}

auto_resize_pane() {
  FILE_MANAGER_PANE_ID=$(__get_file_manager_pane_id "$ORIGIN_SESSION" "$ORIGIN_WINDOW")
  if __is_pane_id_exists "$FILE_MANAGER_PANE_ID"; then
    tmux resize-pane -t "$FILE_MANAGER_PANE_ID" -x "$FIXED_RESIZE_TMUX_LEFT_OR_RIGHT"
  fi
}

reset_pane_workspaces() {
  update_global_pane_ids

  FILE_MANAGER_PANE_ID=$(__get_file_manager_pane_id "$CURRENT_SESSION" "$WINDOW_ID")
  if ! __is_pane_id_exists "$FILE_MANAGER_PANE_ID" || [[ "$FILE_MANAGER_PANE_ID" == "$MAIN_PANE_ID" ]]; then
    __send_notify "workspaces_notify_warn" "Create base layout first"
    tmux select-layout -E
    exit
  fi

  tmux resize-pane -t "$FILE_MANAGER_PANE_ID" -x "$FIXED_RESIZE_TMUX_LEFT_OR_RIGHT"
}

_get_pane_below_main_pane_id() {
  local target_pane="$1"

  # Scope ke window asal agar tidak nyasar ke window lain
  tmux list-panes -t "$ORIGIN_TARGET" \
    -F "#{pane_id} #{pane_top} #{pane_bottom} #{pane_left} #{pane_right}" |
    awk -v target="$target_pane" '
      $1 == target {
        t_bottom = $3; t_left = $4; t_right = $5; next
      }
      $2 > t_bottom && $2 <= t_bottom + 2 && $4 < t_right && $5 > t_left {
        print $1
      }
    '
}

_reset_pane_size() {
  tmux select-layout -E
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ SETTINGS MAIN WORKSPACE                                  ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

update_global_pane_ids() {
  CURRENT_SESSION="$ORIGIN_SESSION"
  WINDOW_ID="$ORIGIN_WINDOW"

  MAIN_PANE_ID=$(__get_main_pane_id "$CURRENT_SESSION" "$WINDOW_ID")

  if ! __is_pane_id_exists "$MAIN_PANE_ID"; then
    __send_notify "workspaces_notify" "A new main pane (ID) has been successfully updated!"
    MAIN_PANE_ID="$ORIGIN_PANE"
    __update_main_pane_id "$CURRENT_SESSION" "$WINDOW_ID" "$MAIN_PANE_ID"
  fi

  if ! __is_current_session_exits_from_json "$CURRENT_SESSION"; then
    local cwd
    cwd=$(tmux display-message -p -t "$ORIGIN_PANE" '#{pane_current_path}')
    __update_session_obj "$CURRENT_SESSION" "$MAIN_PANE_ID" "$WINDOW_ID" "$cwd"
  fi

  if ! __is_current_window_id_session_exits_from_json "$CURRENT_SESSION" "$WINDOW_ID"; then
    local cwd
    cwd=$(tmux display-message -p -t "$ORIGIN_PANE" '#{pane_current_path}')
    __update_window_obj "$CURRENT_SESSION" "$MAIN_PANE_ID" "$WINDOW_ID" "$cwd"
  fi
}

setup_layout_workspace() {
  local layout="$1"

  if [[ "$layout" == "left" ]]; then
    open_vsplit
    tmux splitw -fhb \; swapp -t ! \; killp -t !
    _go_right

    local pane_id_most_left
    pane_id_most_left=$(tmux list-panes -t "$ORIGIN_TARGET" \
      -F "#{pane_id} #{pane_left}" | sort -nk2 | head -n1 | awk '{print $1}')
    tmux resize-pane -t "$pane_id_most_left" -x "$FIXED_RESIZE_TMUX_LEFT_OR_RIGHT"
  fi

  if [[ "$layout" == "right" ]]; then
    open_vsplit
    tmux splitw -fh \; swapp -t ! \; killp -t !
    _go_right

    local pane_id_most_right
    pane_id_most_right=$(tmux list-panes -t "$ORIGIN_TARGET" \
      -F "#{pane_id} #{pane_right}" | sort -nk2 | tail -n1 | awk '{print $1}')
    tmux resize-pane -t "$pane_id_most_right" -x "$FIXED_RESIZE_TMUX_LEFT_OR_RIGHT"
  fi

  # Setelah split, update ORIGIN_PANE ke pane aktif yang baru (main pane)
  ORIGIN_PANE=$(tmux display-message -p -t "$ORIGIN_TARGET" '#{pane_id}')
  CURRENT_CWD=$(tmux display-message -p -t "$ORIGIN_PANE" '#{pane_current_path}')

  CURRENT_SESSION="$ORIGIN_SESSION"
  WINDOW_ID="$ORIGIN_WINDOW"
  MAIN_PANE_ID="$ORIGIN_PANE"

  __init_json_file
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ FILE MANAGER                                             ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

_close_running_process() {
  local pane_id="$1"
  local process="$2"

  case "$process" in
  nvim) tmux send-keys -t "$pane_id" Escape ":q!" C-m ;;
  yazi) tmux send-keys -t "$pane_id" "q" C-m ;;
  watch) tmux send-keys -t "$pane_id" "c-c" C-m ;;
  esac

  for _ in {1..20}; do
    local current_cmd
    current_cmd=$(tmux display -p -t "$pane_id" '#{pane_current_command}' | tr -d '\n')
    [[ "$current_cmd" != "$process" ]] && break
    sleep 0.1
  done

  tmux send-keys -t "$pane_id" "clear" C-m
}

_open_file_manager_in_pane() {
  tmux send-keys -t "$1" "clear" C-m
  tmux send-keys -t "$1" "$FILE_MANAGER" C-m
}

# ─[ Handle file manager ]──────────────────────────────────────────────

handle_open_filetree() {
  if [[ "$GET_TOTAL_ACTIVE_PANES" == 1 ]]; then
    setup_layout_workspace "$LAYOUT_SIDE"
  fi

  update_global_pane_ids

  FILE_MANAGER_PANE_ID=$(__get_file_manager_pane_id "$CURRENT_SESSION" "$WINDOW_ID")

  if ! __is_pane_id_exists "$FILE_MANAGER_PANE_ID" || [[ "$FILE_MANAGER_PANE_ID" == "$MAIN_PANE_ID" ]]; then
    if [[ "$LAYOUT_SIDE" == "left" ]]; then
      FILE_MANAGER_PANE_ID=$(
        tmux list-panes -t "$ORIGIN_TARGET" -F "#{pane_id} #{pane_left}" |
          sort -nk2 | head -n1 | awk '{print $1}'
      )
    else
      FILE_MANAGER_PANE_ID=$(
        tmux list-panes -t "$ORIGIN_TARGET" -F "#{pane_id} #{pane_right}" |
          sort -nk2 | tail -n1 | awk '{print $1}'
      )
    fi
    __update_pane_file_manager_id "$CURRENT_SESSION" "$WINDOW_ID" "$FILE_MANAGER_PANE_ID"
  fi

  if [[ -z "$FILE_MANAGER_PANE_ID" ]]; then
    __send_notify "workspaces_notify_warn" "File manager pane not found"
    return 1
  fi

  if [[ "$FILE_MANAGER_PANE_ID" == "$MAIN_PANE_ID" ]]; then
    __send_notify "workspaces_notify_warn" "Layout belum siap, buat layout dulu"
    return 1
  fi

  local cmd_process
  cmd_process=$(tmux display -p -t "$FILE_MANAGER_PANE_ID" '#{pane_current_command}' | tr -d '\n')

  if [[ "$cmd_process" == "yazi" || "$cmd_process" == "nvim" || "$cmd_process" == "watch" ]]; then
    _close_running_process "$FILE_MANAGER_PANE_ID" "$cmd_process"
    tmux select-pane -t "$FILE_MANAGER_PANE_ID" -P "bg=$TMUX_BG"
    _go_select_pane_with_id "$MAIN_PANE_ID"
    return
  fi

  _go_select_pane_with_id "$FILE_MANAGER_PANE_ID"
  _open_file_manager_in_pane "$FILE_MANAGER_PANE_ID"
  tmux select-pane -t "$FILE_MANAGER_PANE_ID" -P "bg=$FM_BG"
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ SPLIT TERMINAL                                           ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

handle_split_term() {
  if [[ "$GET_TOTAL_ACTIVE_PANES" == 1 ]]; then
    setup_layout_workspace "$LAYOUT_SIDE"
  fi

  update_global_pane_ids

  TOGGLE_TERM_PANE_ID=$(__get_toggle_term_id "$CURRENT_SESSION" "$WINDOW_ID")
  if ! __is_pane_id_exists "$TOGGLE_TERM_PANE_ID" || [[ "$TOGGLE_TERM_PANE_ID" == "$MAIN_PANE_ID" ]]; then

    _go_select_pane_with_id "$MAIN_PANE_ID"

    local get_pane_id_below_main_id
    get_pane_id_below_main_id=$(_get_pane_below_main_pane_id "$MAIN_PANE_ID")

    if [[ -n "$get_pane_id_below_main_id" ]]; then
      _go_select_pane_with_id "$get_pane_id_below_main_id"
      TOGGLE_TERM_PANE_ID=$(tmux split-window -hl 20 \
        -c '#{pane_current_path}' -P -F "#{pane_id}")
      _reset_pane_size
    else
      TOGGLE_TERM_PANE_ID=$(tmux split-window -vl 20 \
        -c '#{pane_current_path}' -P -F "#{pane_id}")
    fi

    __update_pane_toggle_term "$CURRENT_SESSION" "$WINDOW_ID" "$TOGGLE_TERM_PANE_ID"
  fi

  # Cek posisi pane saat ini (dari origin pane)
  local is_at_top is_at_bottom
  is_at_top=$(tmux display -p -t "$ORIGIN_PANE" '#{pane_at_top}')
  is_at_bottom=$(tmux display -p -t "$ORIGIN_PANE" '#{pane_at_bottom}')

  if [[ "$is_at_top" == 1 && "$is_at_bottom" == 1 ]]; then
    if [[ "$ORIGIN_PANE" != "$TOGGLE_TERM_PANE_ID" ]]; then
      _go_select_pane_with_id "$MAIN_PANE_ID"
    else
      tmux split-window -vl 15 -c '#{pane_current_path}'
      _go_select_pane_with_id "$TOGGLE_TERM_PANE_ID"
    fi
    return
  fi

  if [[ "$is_at_top" == 1 && "$is_at_bottom" == 0 ]]; then
    _go_select_pane_with_id "$TOGGLE_TERM_PANE_ID"
    tmux resize-pane -t "$TOGGLE_TERM_PANE_ID" -y "$FIXED_HEIGHT_BELOW_PANE"
  elif [[ "$is_at_top" == 0 && "$is_at_bottom" == 1 ]]; then
    if [[ "$MAIN_PANE_ID" == "$ORIGIN_PANE" ]]; then
      _go_select_pane_with_id "$TOGGLE_TERM_PANE_ID"
      tmux resize-pane -y "$FIXED_HEIGHT_BELOW_PANE"
    else
      _go_select_pane_with_id "$MAIN_PANE_ID"
      tmux resize-pane -t "$MAIN_PANE_ID" -y "$FIXED_HEIGHT_MAIN_PANE"
    fi
  fi
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ SHOW NOTES                                               ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

handle_show_notes() {
  if [[ "$GET_TOTAL_ACTIVE_PANES" == 1 ]]; then
    setup_layout_workspace "$LAYOUT_SIDE"
  fi

  update_global_pane_ids

  FILE_MANAGER_PANE_ID=$(__get_file_manager_pane_id "$CURRENT_SESSION" "$WINDOW_ID")
  if ! __is_pane_id_exists "$FILE_MANAGER_PANE_ID" || [[ "$FILE_MANAGER_PANE_ID" == "$MAIN_PANE_ID" ]]; then
    FILE_MANAGER_PANE_ID=$(
      tmux list-panes -t "$ORIGIN_TARGET" -F "#{pane_id} #{pane_left}" |
        sort -nk2 | head -n1 | awk '{print $1}'
    )
    __update_pane_file_manager_id "$CURRENT_SESSION" "$WINDOW_ID" "$FILE_MANAGER_PANE_ID"
  fi

  local cmd_process
  cmd_process=$(tmux display -p -t "$FILE_MANAGER_PANE_ID" '#{pane_current_command}' | tr -d '\n')

  if [[ "$cmd_process" == "yazi" || "$cmd_process" == "nvim" || "$cmd_process" == "watch" ]]; then
    _close_running_process "$FILE_MANAGER_PANE_ID" "$cmd_process"
  fi

  _send_keys_to_pane "$FILE_MANAGER_PANE_ID" \
    "watch -t -n 1 $HOME/.config/miscxrdb/bin/_task_doit_now run"
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ FLOAT TERMINAL                                           ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

float_term() {
  local session="tmp_float_term"

  if ! session_exists "$session"; then
    tmux display-popup -d '#{pane_current_path}' -w '100%' -h '50%' -x '80%' -y '80%' \
      -S "bg=$COL_BORDER_BG,fg=$COL_BORDER_FG" \
      -b rounded \
      -E "tmux new -A -s $session 'tmux setw status off; tmux set -w pane-border-status off; tmux set -w detach-on-destroy on; TMUX_SESSION=$session zsh;'"
  else
    if [[ $(tmux display-message -p '#S') == "$session" ]]; then
      tmux detach-client
    else
      tmux display-popup -d '#{pane_current_path}' -w '100%' -h '50%' -x '80%' -y '80%' \
        -S "bg=$COL_BORDER_BG,fg=$COL_BORDER_FG" \
        -b rounded \
        -E "tmux attach -t $session"
    fi
  fi
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ CLOCK AND POMODORO                                       ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

open_clock_mode() {
  local clock_mode="$1"
  local pomodoro_time="$2"

  update_global_pane_ids

  [[ -z "$CURRENT_SESSION" ]] && __send_notify "workspaces_notify" "Create base layout first" && exit

  _go_select_pane_with_id "$MAIN_PANE_ID"

  CLOCK_PANE_ID=$(__get_clock_pane_id "$CURRENT_SESSION" "$WINDOW_ID")
  if ! __is_pane_id_exists "$CLOCK_PANE_ID" || [[ -z "$CLOCK_PANE_ID" ]]; then
    FILE_MANAGER_PANE_ID=$(__get_file_manager_pane_id "$CURRENT_SESSION" "$WINDOW_ID")
    if ! __is_pane_id_exists "$FILE_MANAGER_PANE_ID" || [[ "$FILE_MANAGER_PANE_ID" == "$MAIN_PANE_ID" ]]; then
      __send_notify "workspaces_notify" "Create base layout first"
      exit
    fi

    CLOCK_PANE_ID=$(tmux split-pane -v -p 25 -l 10 \
      -c '#{pane_current_path}' -t "$FILE_MANAGER_PANE_ID" -P -F '#{pane_id}')
    __update_pane_clock_id "$CURRENT_SESSION" "$WINDOW_ID" "$CLOCK_PANE_ID"
  fi

  tmux select-pane -t "$MAIN_PANE_ID"

  # Tunggu sampai bukan tclock lagi
  for _ in {1..10}; do
    local current_cmd
    current_cmd=$(tmux display -p -t "$CLOCK_PANE_ID" '#{pane_current_command}' | tr -d '\n')
    [[ "$current_cmd" == "tclock" ]] && _send_keys_to_pane "$CLOCK_PANE_ID" "q"
    [[ "$current_cmd" != "tclock" ]] && break
    sleep 0.1
  done

  if command -v tclock &>/dev/null; then
    if [[ "$clock_mode" == "clock" ]]; then
      _send_keys_to_pane "$CLOCK_PANE_ID" "tclock -c '$COLOR_CLOCK' clock -S"
    elif [[ "$clock_mode" == "pomodoro" ]]; then
      _send_keys_to_pane "$CLOCK_PANE_ID" "tclock -c '$COLOR_CLOCK' timer -d $pomodoro_time -M"
    fi
  else
    tmux clock-mode
  fi
}

clock_mode() { open_clock_mode "clock" ""; }
pomodoro_1hour() { open_clock_mode "pomodoro" "1h"; }
pomdoro_30minute() { open_clock_mode "pomodoro" "30m"; }
pomdoro_25minute() { open_clock_mode "pomodoro" "25m"; }
pomdoro_5minute() { open_clock_mode "pomodoro" "5m"; }

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ GO LAST SESSION                                          ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

last_session() {
  local current_session previous_session total_sessions
  current_session=$(tmux display-message -p '#S')
  previous_session=$(tmux display-message -p '#{client_last_session}')
  total_sessions=$(tmux list-sessions | wc -l)

  if [[ "$total_sessions" -eq 1 ]]; then
    local msg="No alternate session available. Aborting!"
    local cols padding spaces
    cols=$(tmux display -p "#{client_width}")
    padding=$(((cols - ${#msg}) / 2))
    spaces=$(printf '%*s' "$padding")
    tmux display-message "#[fill=$RED fg=colour0,bg=colour1,bold]${spaces}${msg}"
    return
  fi

  if [[ -z "$previous_session" ]]; then
    tmux display-message "⚠️  The last session no longer exists. Try selecting another one."
    return
  fi

  tmux switch-client -l
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ TMUX PLUGIN HELPER                                       ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

_send_message() {
  local messages="$1"
  local title="${2:-open_in_nvim}"
  __send_notify "$title" "$messages"
}

_open_in_nvim() {
  if [[ "$GET_TOTAL_ACTIVE_PANES" == 1 ]]; then
    setup_layout_workspace "$LAYOUT_SIDE"
  fi
  update_global_pane_ids

  local path="$1"
  local line="$2"
  local pane_id
  pane_id="$(__get_main_pane_id "$ORIGIN_SESSION" "$ORIGIN_WINDOW")"

  if [[ -z "$pane_id" ]]; then
    _send_message "Open in nvim failed: no target pane found (session=$ORIGIN_SESSION, window=$ORIGIN_WINDOW)"
    return 1
  fi

  if [[ -z "$path" ]]; then
    _send_message "Open in nvim failed: empty file path"
    return 1
  fi

  if [[ ! -f "$path" ]]; then
    _send_message "Open in nvim warning: file not found → $path"
    return 1
  fi

  _go_select_pane_with_id "$pane_id"
  _send_keys_to_pane "$pane_id" ":vsplit $path"

  if [[ -n "$line" ]]; then
    _send_keys_to_pane "$pane_id" ":$line"
  fi

  if [[ -n "$line" ]]; then
    _send_message "$(basename "$path"):$line"
  else
    _send_message "$(basename "$path")"
  fi
}

jump_to_main_pane() {
  local file_path
  file_path=$(cat)

  case "$file_path" in
  file://*)
    local file_name="${file_path/file:\/\//}"
    file_name="$(echo "$file_name" | cut -d":" -f1)"
    _open_in_nvim "$file_name"
    ;;
  *:[0-9]*)
    local file_name line_number
    file_name=$(echo "$file_path" | cut -d':' -f1)
    line_number=$(echo "$file_path" | cut -d':' -f2)
    _open_in_nvim "$file_name" "$line_number"
    ;;
  *\",[[:space:]]line*)
    local file_name line_number
    file_name=$(echo "$file_path" | cut -d'"' -f1)
    line_number=$(echo "$file_path" | rev | cut -d' ' -f1 | rev)
    _open_in_nvim "$file_name" "$line_number"
    ;;
  https://*)
    open "$file_path"
    _send_message "Open $file_path" "Open In Browser"
    ;;
  *)
    _send_message "No selection. No pattern. Abort it" "Tm_Toggle_Pane"
    ;;
  esac
}

"$@"
