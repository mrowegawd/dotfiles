#!/bin/bash

LAYOUT_SIDE="left"

FIXED_HEIGHT_BELOW_PANE=15
FIXED_HEIGHT_MAIN_PANE=50
FILE_MANAGER="$TERM_FILEMANAGER"

# COL_BG=$(xrdb -query | grep -i background | cut -d':' -f2 | head -1 | xargs)

COL_BORDER_FG=$(xrdb -query | grep -i .color16 | cut -d':' -f2 | head -1 | xargs)
COL_BORDER_BG=$(xrdb -query | grep -i background | cut -d':' -f2 | xargs)

TMUX_SNAPSHOT_PATH="$HOME/.config/tmuxconfig/themes/tmux-snapshot"
if [ -f "$TMUX_SNAPSHOT_PATH" ]; then
  COL_BORDER_BG=$(grep -i TMUX_BG <"$TMUX_SNAPSHOT_PATH" | head -1 | cut -d"=" -f2 | sed s/\"//g)
  # COL_RED=$(grep -i RED <"$TMUX_SNAPSHOT_PATH" | head -1 | cut -d"=" -f2 | sed s/\"//g)
fi

GET_TOTAL_ACTIVE_PANES=$(tmux display-message -p '#{window_panes}')

current_session=$(tmux display-message -p '#S')
PATH_PANE_COLLECT_JSON="/tmp/tmux-toggle-pane-$current_session.json"

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ SESSION HELPER                                           ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘
#
# Check if a tmux session exists
session_exists() {
  tmux has-session -t "=$1" 2>/dev/null
}

# Check if currently not inside tmux
not_in_tmux() {
  [[ -z "$TMUX" ]]
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ UTILS                                                    ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

# Generic check for the current pane’s running command
_check_pane_is() {
  local target_cmd="$1"
  local current_cmd
  current_cmd=$(tmux display-message -p "#{pane_current_command}" 2>/dev/null | tr -d '\n')
  [[ "$current_cmd" == "$target_cmd" ]]
}

_check_pane_is_nvim() { _check_pane_is "nvim"; }
_check_pane_is_uv() { _check_pane_is "uv"; }
_check_pane_is_yazi() { _check_pane_is "yazi"; }
_check_pane_is_zsh() { _check_pane_is "zsh"; }
_check_pane_is_tclock() { _check_pane_is "tclock"; }

# Check if a pane ID exists across all sessions
_check_pane_if_exists() {
  local pane_id="$1"
  [[ -n "$pane_id" ]] && tmux list-panes -a -F "#{pane_id}" | grep -q "^${pane_id}$"
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ NAVIGATION                                               ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

_go_left() { tmux select-pane -L; }
_go_right() { tmux select-pane -R; }
_go_select_pane_with_id() { tmux select-pane -t "$1"; }
_go_last_pane() { tmux last-pane; }

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ JSON HELPER                                              ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

__init_json_file() {
  [[ ! -f $PATH_PANE_COLLECT_JSON ]] && touch "$PATH_PANE_COLLECT_JSON"
  if [[ ! -s $PATH_PANE_COLLECT_JSON ]]; then
    json_output=$(
      cat <<EOF
[
  {
    "window_id": "$window_id",
    "main_pane_id": "$main_pane_id",
    "file_manager_pane_id": "",
    "toggle_term_pane_id": "",
    "cwd": "$current_cwd",
    "session": "$current_session",
    "file_manager_layout": "$LAYOUT_SIDE"
  }
]
EOF
    )
    echo "$json_output" >"$PATH_PANE_COLLECT_JSON"
  fi
}

__update_json_file() {
  local id="$1"
  local field="$2"

  if [[ -z "$id" || -z "$field" ]]; then
    dunstify "Error: Missing arguments for JSON update"
    return 1
  fi

  jq --arg id "$id" --arg field "$field" \
    '.[0][$field] = $id' "$PATH_PANE_COLLECT_JSON" \
    >tmp.json && mv tmp.json "$PATH_PANE_COLLECT_JSON"
}
__update_pane_file_manager_id() {
  local pane_id="$1"
  if [[ -z "$pane_id" ]]; then
    dunstify "⚠️  File manager pane ID is empty!"
  else
    __update_json_file "$pane_id" "file_manager_pane_id"
  fi
}
__update_pane_toggle_term() {
  local pane_id="$1"
  if [[ -z "$pane_id" ]]; then
    dunstify "⚠️  Toggle term pane ID is empty!"
  else
    __update_json_file "$pane_id" "toggle_term_pane_id"
  fi
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ PANE SPLIT HELPERS                                       ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

open_vsplit() {
  local pane_count
  pane_count=$(tmux list-panes | wc -l)

  if [[ "$pane_count" -gt 1 ]]; then
    tmux split-window -h -c '#{pane_current_path}'
  else
    tmux split-window -hl 80 -c '#{pane_current_path}'
  fi
}
open_split() {
  local pane_count
  pane_count=$(tmux list-panes | wc -l)

  if [[ "$pane_count" -gt 1 ]]; then
    tmux split-window -v -l 20 -c '#{pane_current_path}'
  else
    tmux split-window -v -l 20 -c '#{pane_current_path}'
  fi
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ SETTINGS MAIN WORKSPACE                                  ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

get_main_pane_id_workspace() {
  if [[ ! -f "$PATH_PANE_COLLECT_JSON" ]]; then
    pane_id_exists=$(jq -e --arg pid "$CURRENT_PANE" '.[] | select(.pane_id == $pid)' "$PATH_PANE_COLLECT_JSON")
    if [[ "$pane_id_exists" == "" ]]; then
      rm "$PATH_PANE_COLLECT_JSON"
    fi
  fi

  main_pane_id=$(tmux display-message -p '#{pane_id}')
  window_id=$(tmux display-message -p '#I')
  current_cwd=$(pwd)
  current_session=$(tmux display-message -p '#S')

  __init_json_file
}

create_base_layout() {
  open_vsplit

  if [[ "$1" == "left" ]]; then
    # set pane to the most left
    tmux splitw -fhb \; swapp -t ! \; killp -t !
    _go_right

    pane_id_most_left=$(tmux list-panes -F "#{pane_id} #{pane_left}" | sort -nk2 | head -n1 | awk '{print $1}')
    tmux resize-pane -t "$pane_id_most_left" -x 40
  fi
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ FILE MANAGER                                             ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

_close_running_process() {
  local pane_id="$1"
  local process="$2"

  case "$process" in
  nvim)
    tmux send-keys -t "$pane_id" Escape ":q!" C-m
    ;;
  yazi)
    tmux send-keys -t "$pane_id" "q" C-m
    ;;
  esac

  # Tunggu hingga proses selesai tertutup
  for _ in {1..20}; do
    local current_cmd
    current_cmd=$(tmux display -p -t "$pane_id" '#{pane_current_command}' | tr -d '\n')
    [[ "$current_cmd" != "$process" ]] && break
    sleep 0.1
  done

  tmux send-keys -t "$pane_id" "clear" C-m
}

_open_file_manager_window_under_pane() {
  tmux send-keys -t "$1" "clear" C-m
  tmux send-keys -t "$1" "$FILE_MANAGER" C-m
}

_get_pane_id_left_or_right() {
  local pane_left_or_right

  CURRENT_PANE=$(tmux display-message -p '#{pane_id}')

  if [[ $1 == "left" ]]; then
    pane_left_or_right=$(tmux display -p '#{pane_at_left}')
    if [ "$pane_left_or_right" == 0 ]; then
      tmux list-panes -F '#{pane_id} #{pane_left} #{pane_active}' | awk -v cur="$CURRENT_PANE" '
        $3 = 1 {cur_left = $2} $2 == cur_left {print $1} ' | head -n 1
    fi
  fi

  if [[ $1 == "right" ]]; then
    pane_left_or_right=$(tmux display -p '#{pane_at_right}')
    if [ "$pane_left_or_right" == 0 ]; then
      tmux list-panes -F '#{pane_id} #{pane_left}' | awk '
      NR == 1 || $2 > max_left {max_left = $2; rightmost = $1}
      END {print rightmost} '
    fi
  fi
}

# ─[ Handle file manager ]──────────────────────────────────────────────

handle_open_filetree() {
  # 1️⃣ Pastikan layout dasar tersedia
  if [[ "$GET_TOTAL_ACTIVE_PANES" == 1 ]]; then
    create_base_layout "$LAYOUT_SIDE"
  fi

  # 2️⃣ Ambil dan verifikasi pane utama
  local MAIN_PANE_ID FILE_MANAGER_PANE_ID CURRENT_PANE TARGET_PANE_FOR_FILEMANAGER COMMAND_PROCESS
  MAIN_PANE_ID=$(jq -r '.[0].main_pane_id' "$PATH_PANE_COLLECT_JSON")

  if ! _check_pane_if_exists "$MAIN_PANE_ID"; then
    dunstify "Main pane ID not found — recreating..."
    MAIN_PANE_ID=$(get_main_pane_id_workspace)
  fi

  # 3️⃣ Ambil dan verifikasi pane untuk file manager
  FILE_MANAGER_PANE_ID=$(jq -r '.[0].file_manager_pane_id' "$PATH_PANE_COLLECT_JSON")
  if ! _check_pane_if_exists "$FILE_MANAGER_PANE_ID"; then
    dunstify "File manager pane not found — locating most left pane..."
    FILE_MANAGER_PANE_ID=$(
      tmux list-panes -F "#{pane_id} #{pane_left}" |
        sort -nk2 | head -n1 | awk '{print $1}'
    )
    __update_pane_file_manager_id "$FILE_MANAGER_PANE_ID"
  fi

  CURRENT_PANE=$(tmux display-message -p '#{pane_id}')
  TARGET_PANE_FOR_FILEMANAGER=$(_get_pane_id_left_or_right "$LAYOUT_SIDE")

  # 4️⃣ Dapatkan proses aktif di file manager pane
  COMMAND_PROCESS=$(tmux display -p -t "$FILE_MANAGER_PANE_ID" '#{pane_current_command}' | tr -d '\n')

  # 5️⃣ Jika pane target tidak ditemukan → kembali ke pane utama
  if [[ -z "$TARGET_PANE_FOR_FILEMANAGER" ]]; then
    _go_select_pane_with_id "$MAIN_PANE_ID"
    return
  fi

  # 6️⃣ Tutup proses tertentu bila masih aktif
  if [[ "$COMMAND_PROCESS" == "yazi" || "$COMMAND_PROCESS" == "nvim" ]]; then
    _close_running_process "$FILE_MANAGER_PANE_ID" "$COMMAND_PROCESS"
    _go_select_pane_with_id "$MAIN_PANE_ID"
    return
  fi

  # 7️⃣ Jika tidak ada proses aktif → fokus ke pane file manager dan buka file manager
  _go_select_pane_with_id "$FILE_MANAGER_PANE_ID"
  _open_file_manager_window_under_pane "$FILE_MANAGER_PANE_ID"
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ SPLIT TERMINAL                                           ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

handle_split_term() {
  if [ "$GET_TOTAL_ACTIVE_PANES" == 1 ]; then
    create_base_layout "$LAYOUT_SIDE"
  fi

  CURRENT_PANE=$(tmux display-message -p '#{pane_id}')

  MAIN_PANE_ID=$(jq -r '.[0].main_pane_id' "$PATH_PANE_COLLECT_JSON")
  if ! _check_pane_if_exists "$MAIN_PANE_ID"; then
    dunstify "Create main pane ID"
    MAIN_PANE_ID=$(get_main_pane_id_workspace)
  fi

  TOGGLE_TERM_PANE_ID=$(jq -r '.[0].toggle_term_pane_id' "$PATH_PANE_COLLECT_JSON")
  if ! _check_pane_if_exists "$TOGGLE_TERM_PANE_ID"; then
    dunstify "Create toggle terminal pane ID"

    # Split pane dan ambil pane_id yang baru dibuat
    tmux_split=$(tmux split-window -vl 20 -c '#{pane_current_path}' -P -F "#{pane_id}")

    # Simpan atau update ke toggle term
    __update_pane_toggle_term "$tmux_split"
  fi

  IS_PANE_AT_TOP=$(tmux display -p '#{pane_at_top}')
  IS_PANE_AT_BELLOW=$(tmux display -p '#{pane_at_bottom}')

  # dunstify "Is pane top: $IS_PANE_AT_TOP"
  # dunstify "Is pane below: $IS_PANE_AT_BELLOW"

  # Kondisi ini jika posisi pane hanya satu,
  # yakni dia juga below dan juga posisi top
  if [[ "$IS_PANE_AT_TOP" == 1 ]] && [[ "$IS_PANE_AT_BELLOW" == 1 ]]; then
    if [[ ! $CURRENT_PANE == "$TOGGLE_TERM_PANE_ID" ]]; then
      _go_select_pane_with_id "$MAIN_PANE_ID"
    else

      tmux split-window -vl 15 -c '#{pane_current_path}'
    fi
  fi

  if [[ "$IS_PANE_AT_TOP" == 1 ]] && [[ "$IS_PANE_AT_BELLOW" == 0 ]]; then

    CURRENT_BOTTOM=$(tmux display-message -p "#{pane_bottom}")
    CURRENT_LEFT=$(tmux display-message -p "#{pane_left}")
    CURRENT_RIGHT=$(tmux display-message -p "#{pane_right}")

    PANE_BELOW=$(tmux list-panes -F "#{pane_id} #{pane_top} #{pane_bottom} #{pane_left} #{pane_right}" |
      awk -v cb="$CURRENT_BOTTOM" -v cl="$CURRENT_LEFT" -v cr="$CURRENT_RIGHT" '
      $2 > cb && $4 >= cl && $5 <= cr { print $0 }' | sort -nk2 | head -n1 | awk '{print $1}')

    __update_pane_toggle_term "$PANE_BELOW"
    _go_select_pane_with_id "$PANE_BELOW"
    tmux resize-pane -t "$PANE_BELOW" -y "$FIXED_HEIGHT_BELOW_PANE"

  elif
    [[ "$IS_PANE_AT_TOP" == 0 ]] && [[ "$IS_PANE_AT_BELLOW" == 1 ]]
  then
    if [[ $MAIN_PANE_ID == "$CURRENT_PANE" ]]; then
      _go_select_pane_with_id "$TOGGLE_TERM_PANE_ID"
      tmux resize-pane -y "$FIXED_HEIGHT_BELOW_PANE"
    else
      _go_select_pane_with_id "$MAIN_PANE_ID"
      tmux resize-pane -t "$MAIN_PANE_ID" -y "$FIXED_HEIGHT_MAIN_PANE"
    fi

  fi
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ FLOAT TERMINAL                                           ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

float_term() {
  session="tmp_float_term"

  if ! session_exists "$session"; then
    set -gF '@last_session_name' '#S'
    tmux display-popup -d '#{pane_current_path}' -w '100%' -h '50%' -x '80%' -y '80%' \
      -E -d "#{pane_current_path}" \
      -S bg="$COL_BORDER_BG",fg="$COL_BORDER_FG" \
      -b rounded \
      -E "tmux new -A -s $session 'tmux setw status off; tmux set -w pane-border-status off; tmux set -w detach-on-destroy on; TMUX_SESSION=$session zsh;'"
  else
    if [[ $(tmux display-message -p '#S') == "$session" ]]; then
      tmux detach-client
    else
      tmux display-popup -d '#{pane_current_path}' -w '100%' -h '50%' -x '80%' -y '80%' \
        -S bg="$COL_BORDER_BG",fg="$COL_BORDER_FG" \
        -b rounded \
        -E -d "#{pane_current_path}" \
        -E "tmux attach -t $session"
    fi
  fi
}

# ┌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┐
# ╎ GO LAST SESSION                                          ╎
# └╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌╌┘

last_session() {
  # Ambil sesi saat ini dan sesi sebelumnya
  local current_session previous_session
  current_session=$(tmux display-message -p '#S')
  previous_session=$(tmux display-message -p '#{client_last_session}')

  # Hitung total sesi yang ada
  local total_sessions
  total_sessions=$(tmux list-sessions | wc -l)

  # Jika hanya ada 1 sesi, tampilkan pesan error di tengah
  if [[ "$total_sessions" -eq 1 ]]; then
    local msg="No alternate session available. Aborting!"
    local cols padding spaces
    #
    cols=$(tmux display -p "#{client_width}")
    padding=$(((cols - ${#msg}) / 2))
    spaces=$(printf '%*s' "$padding")

    tmux display-message "#[fill=$RED fg=colour0,bg=colour1,bold]${spaces}${msg}"
    return
  fi

  # Jika sesi sebelumnya tidak valid atau tidak ada
  if [[ -z "$previous_session" ]]; then
    tmux display-message "⚠️  The last session no longer exists. Try selecting another one."
    return
  fi

  # Berpindah ke sesi terakhir yang valid
  tmux switch-client -l
}

"$@"
