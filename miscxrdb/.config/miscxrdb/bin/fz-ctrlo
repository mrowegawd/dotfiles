note_set_dummy() {
  local pomodoro_icon="$HOME/.config/miscxrdb/icons/pomodoro.png"
  dunstify -i "$pomodoro_icon" "To Do Now" "PRIORITY and PROGRESS tracking disabled!"
}

#  +----------------------------------------------------------+
#  |                         MENULIST                         |
#  +----------------------------------------------------------+

callme() {
  MENULIST=$(
    cat <<EOF
 calculator
 calendar
 ps-lsof
 apt: service system UI
 apt: search
󰷛 btop
 tmux: toggle status
 tmux: toggle synchronize panes
 tmux: clock mode
 tmux: select session
 tmux: capture pane
 tmux: capture pane with files
 tmux: clear main pane id
 tmux: kill/clear other panes
 tmux: reset workspace pane size
 Note: set DUMMY and CLEAR project todo
 Note: set PRIORITAS todo
 Note: set PROGRESS todo
 pomodoro: 1 hour
 pomodoro: 30 minute
 pomodoro: 25 minute
 pomodoro: 5 minute
󰭲 rkill
 multilog
󰎕 news
 Rust upserv
 Rust upserv 2
 Rust benc
 Grav term
 Log Meta
EOF
  )

  SELECTED=$(echo -e "$MENULIST" | fzf-tmux -xC -w '30%' -h '55%' --prompt="⚡" --border-label ' ALT-O ')
  [[ -z $SELECTED ]] && exit

  SELECT="${SELECTED#* }"

  case $SELECT in
  "calculator") open_calc ;;
  "calendar") open_calcure ;;
  "ps-lsof") open_ps_lsof ;;
  "btop") open_ps_btop ;;
  "apt: search") show_apt_search ;;
  "apt: service system UI") open_systemctl_ui ;;
  "tmux: clock mode") tmux_open_clock ;;
  "tmux: select session") tmux_select_sess ;;
  "tmux: toggle status") tmux_toggle_status ;;
  "tmux: toggle synchronize panes") tmux_toggle_synchronize_panes ;;
  "tmux: capture pane") capture_pane ;;
  "tmux: capture pane with files") capture_pane_and_save_to_file ;;
  "tmux: clear main pane id") tmux_clear_main_id_workspace ;;
  "tmux: kill/clear other panes") tmux_kill_others_pane ;;
  "tmux: reset workspace pane size") tmux_reset_workspaces ;;
  "Note: set DUMMY and CLEAR project todo") note_set_dummy ;;
  "pomodoro: 1 hour") pomodoro_1hour_mode ;;
  "pomodoro: 30 minute") pomodoro_25minute_mode ;;
  "pomodoro: 25 minute") pomodoro_25minute_mode ;;
  "pomodoro: 5 minute") pomodoro_5minute_mode ;;
  "rkill") open_rkill ;;
  "multilog") open_mutlilog ;;

  "news") open_newsboat ;;
  *) exit ;;
  esac
}

"$@"
