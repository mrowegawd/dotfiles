capture_pane_and_save_to_file() {
  if ! _check_pane_is_zsh; then
    dunstify "[!] Capture pane" "Need to run inside zsh!"
    exit
  fi

  tmux command-prompt -p 'save history to filename:' -I "$HOME/Downloads/tmux.history" 'capture-pane -S -32768 ; save-buffer %1 ; delete-buffer'
}
capture_pane() {
  if ! _check_pane_is_zsh; then
    dunstify "[!] Capture pane" "Need to run inside zsh!"
    exit
  fi

  tmux send-keys "tmux capture-pane -S -32768 ; tmux save-buffer ~/Downloads/tmux.history ; tmux delete-buffer ; nvim ~/Downloads/tmux.history" Enter
}
capture_fzf() {
  SELECT=$(echo -e "Capture pane and save to file\nCapture pane" | fzf-tmux -xC -w '30%' -h '20%' --prompt="Tmux> ")

  [[ -z $SELECT ]] && exit

  case $SELECT in
  "Capture pane and save to file") capture_pane_and_save_to_file ;;
  "Capture pane") capture_pane ;;
  *) exit ;;
  esac
}

#  +----------------------------------------------------------+
#  |                           TMUX                           |
#  +----------------------------------------------------------+

tmux_clock_mode() {
  local PATH_PANE_COLLECT_JSON="/tmp/tmux-main-layout-workspaces.json"
  [[ ! -f $PATH_PANE_COLLECT_JSON ]] && dunstify "Create base layout first" && exit

  __extract_id_from_json() {
    local session_name="$1"
    local window_name="$2"
    local field_name="$3"
    local json_file="$4"

    jq -r --arg session_name "$session_name" --arg window_name "$window_name" \
      --arg field_name "$field_name" '.[$session_name].[$window_name].[$field_name]' "$json_file"
  }

  __get_file_manager_pane_id() {
    local session_name="$1"
    local window_name="$2"
    local json_file="$3"

    __extract_id_from_json "$session_name" "$window_name" "file_manager_pane_id" "$json_file"
  }

  __get_main_pane_id() {
    local session_name="$1"
    local window_name="$2"
    local json_file="$3"

    __extract_id_from_json "$session_name" "$window_name" "main_pane_id" "$json_file"
  }

  local current_session window_id file_manager_pane_id
  current_session=$(tmux display-message -p '#S')
  window_id=$(tmux display-message -p '#I')

  main_pane_id=$(__get_main_pane_id "$current_session" "$window_id" "$PATH_PANE_COLLECT_JSON")
  file_manager_pane_id=$(__get_file_manager_pane_id "$current_session" "$window_id" "$PATH_PANE_COLLECT_JSON")

  if [[ $file_manager_pane_id == "" ]]; then
    dunstify "Pane file manager is empty?"
    exit
  fi

  # dunstify $file_manager_pane_id
  local pane_id_split process
  pane_id_split=$(tmux split-pane -v -p 25 -l 10 -c '#{pane_current_path}' -t "$file_manager_pane_id" -P -F '#{pane_id}')
  process="zsh"

  tmux select-pane -t "$main_pane_id"

  for _ in {1..5}; do
    local current_cmd
    current_cmd=$(tmux display -p -t "$pane_id_split" '#{pane_current_command}' | tr -d '\n')
    [[ "$current_cmd" != "$process" ]] && break
    sleep 0.1
  done

  if command -v tclock &>/dev/null; then

    if [[ "$1" == "clock" ]]; then
      # tclock_command="'tclock clock -S'"
      tmux send-keys -t "$pane_id_split" 'tclock clock -S' Enter
    fi

    if [[ "$1" == "pomodoro" ]]; then
      # tclock_command="'tclock -c red timer -d 25m -M'"
      tmux send-keys -t "$pane_id_split" 'tclock -c red timer -d 25m -M' Enter
    fi
  else
    tmux clock-mode
  fi
}

tmux_open_clock() {
  "$HOME/.config/miscxrdb/bin/tm-toggle-pane" clock_mode
}

tmux_toggle_status() {
  tmux set-option -g status

  if [[ ! -f /tmp/tm_status_toggle ]]; then
    touch /tmp/tm_status_toggle
    tmux set-option -g pane-border-status off
    # dunstify "toggle Off"
  else
    rm /tmp/tm_status_toggle
    tmux set-option -g pane-border-status top
    # dunstify "toggle On"
  fi
}
tmux_toggle_synchronize_panes() {
  file_sync="/tmp/.tmux_toggle_synchronize_panes"
  [[ ! -f $file_sync ]] && touch "$file_sync" && tmux set-window-option synchronize-panes on \; display 'Synchronize Begin Now!' && exit
  [[ -f $file_sync ]] && rm "$file_sync" && tmux set-window-option synchronize-panes off \; display 'Synchronize End!' && exit
}
tmux_select_sess() {
  # session=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | fzf-tmux -xC -w '50%' -h '40%' --exit-0)
  # [[ -z $session ]] && exit
  # tmux switch-client -t "$session"
  SELECT_SESS=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | fzf-tmux -xC -w '50%' -h '40%' --exit-0 --prompt="Select Session> ")
  [[ -z $SELECT_SESS ]] && exit

  tmux switch-client -t "$SELECT_SESS"
}
tmux_create_sess() {
  DROPBOX_PATH="$HOME/Dropbox/data.programming.forprivate"
  MARKED_PWD="$DROPBOX_PATH/marked-pwd"

  SELECT=$(fzf-tmux -xC -w '50%' -h '40%' --prompt='Create New Session> ' <"$MARKED_PWD")

  [[ -z $SELECT ]] && exit
  [[ ! -d $SELECT ]] && notify-send "Path: $SELECT" "Not found!" && exit

  ss_name=$(basename "$SELECT" | sed -e "s/\./\_/g")

  _is_session_exists() {
    tmux has-session -t "=$ss_name"
  }

  if ! _is_session_exists; then
    tmux new-session -d -s "$ss_name" -c "$SELECT"
  fi

  tmux switch-client -t "$ss_name"
  notify-send "create new session and detach --> $ss_name"
}

tmux_kill_others_pane() {
  tmux list-panes -F '#{pane_id} #{pane_active}' | awk '$2==0{print $1}' | xargs -I{} tmux kill-pane -t {}
}

tmux_reset_workspaces() {
  "$HOME/.config/miscxrdb/bin/tm-toggle-pane" reset_pane_workspaces
}

tmux_clear_main_id_workspace() {
  rm /tmp/tmux-main-layout-*
  tmux_kill_others_pane

  dunstify "Cleared tmux main IDs and panes"
}

