#!/bin/bash

DROPBOX_PATH="$HOME/Dropbox/data.programming.forprivate"
MARKED_PWD="$DROPBOX_PATH/marked-pwd"

# Method ini sepertinya ga work pada tmux 3.4 ..?!
# butuh investigasi ini
not_in_tmux() {
	[ -z "$TMUX" ]
}

not_in_tmux_2() {
	tmux_ls=$(tmux ls 2>&1)

	if [[ $tmux_ls == *"no server"* ]]; then
		return 1
	else
		return 0
	fi
}

path_name="$(basename "$PWD" | tr . -)"
session_name=${1-$path_name}

create_detached_session() {
	(TMUX='' tmux new-session -Ad -s "$session_name")
}

create_if_needed_and_attach() {
	not_in_tmux_2
	not_in_tmux=$?

	# jika output 0, dalam tmux mode
	# jika output 1, tidak dalam tmux mode
	if [[ $not_in_tmux == 1 ]]; then
		tmux new-session -As "$session_name" -c "$session_name"
	else
		not_in_tmux_2
		run_fzf_with_tmux=$?

		if [[ $run_fzf_with_tmux == 1 ]]; then
			select=$(fzf --prompt='Create New Session: ' <"$MARKED_PWD")
		else
			select=$(fzf-tmux -xC -w '50%' -h '40%' --prompt='Create New Session: ' <"$MARKED_PWD")
		fi

		[[ -z $select ]] && exit
		[[ ! -d $select ]] && notify-send "Path: $select" "Not found!" && exit

		select_basename=$(basename "$select")

		ss_name=$(echo "$select_basename" | sed -e "s/\./\_/g")

		session_exists() {
			tmux has-session -t "=$ss_name"
		}

		if ! session_exists; then
			tmux new-session -d -s "$ss_name" -c "$select"
		fi

		tmux switch-client -t "$ss_name"
		notify-send "create new session and detach $ss_name"
	fi
}

create_if_needed_and_attach
