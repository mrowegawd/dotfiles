  search = None
  page_down = None
  close_window = None
  resize_up = None
  resize_down = None
  resize_left = None
  resize_right = None
  move_tab_right = None
  move_tab_left = None
  toggle_zoom = None
  scaled_zoom = None
  next_tab = None
  prev_tab = None
  full_screen = None
  reset = None
  reset_clear = None
  hide_window = None
  group_all = None
  group_all_toggle = None
  ungroup_all = None
  group_tab = None
  group_tab_toggle = None
  ungroup_tab = None
  new_window = None
  new_terminator = None
  broadcast_off = None
  broadcast_group = None
  broadcast_all = None
  insert_number = None
  insert_padded = None
  edit_window_title = None
  edit_tab_title = None
  edit_terminal_title = None
  layout_launcher = None
  next_profile = None
  help = None
[profiles]
  [[default]]
    cursor_blink = False
    cursor_color = "#ffffff"
    cursor_color_fg = False
    font = Iosevka Term 9
    use_system_font = False
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
