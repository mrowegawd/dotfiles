{
    "editor.lineNumbers": "relative",
    "editor.stickyScroll.enabled": true,
    "editor.minimap.enabled": false,
    "workbench.startupEditor": "newUntitledFile",
    "editor.suggest.insertMode": "insert",
    // "vscode-neovim.neovimExecutablePaths.linux": "/usr/local/bin/nvim",
    // "vscode-neovim.neovimInitVimPaths.linux": "/home/mr00x/.config/nvim/init.vim",
    "editor.suggestSelection": "first",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "python.jediEnabled": false,
    "vim.easymotion": true,
    "vim.incsearch": true,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.sneak": true,
    "vim.highlightedyank.enable": true,
    "vim.easymotionMarkerooundColor": "#020202",
    "vim.foldfix": true,
    "vim.leader": "<space>",
    "snippets.userSnippetsDirectory": "/home/mr00x/Dropbox/friendly-snippets",
    "snippets.extends": {},
    "vim.normalModeKeyBindings": [
        {
            "before": [ "g", "l" ],
            "commands": [ "workbench.action.nextEditor" ]
        },
        {
            "before": [ "g", "h" ],
            "commands": [ "workbench.action.previousEditor" ]
        },
        {
            "before": [ "K" ],
            "commands": [ "editor.action.showHover" ]
        },

        // Navigate
        {
            "before": [ "s", "h" ],
            "commands": ["workbench.action.focusLeftGroup"]
        },
        {
            "before": [ "s", "l" ],
            "commands": ["workbench.action.focusRightGroup"]
        },
        {
            "before": [ "s", "k" ],
            "commands": ["workbench.action.focusAboveGroup"]
        },
        {
            "before": [ "s", "j" ],
            "commands": ["workbench.action.focusAboveGroup"]
        },
        {
            "before": [ "s", "j" ],
            "commands": ["workbench.action.focusAboveGroup"]
        },
        {
            "before": [ "s", "v" ],
            "commands": ["workbench.action.splitEditor"]
        },
        {
            "before": [ "s", "s" ],
            "commands": ["workbench.action.splitEditorDown"]
        },
        {
            "before": [ "s", "m" ],
            "commands": ["workbench.action.maximizeEditor"]
        },

        // Folds
        // workbench.action.maximizeEditor
        {
            "before": [ "z", "m" ],
            "after": [ "z", "M" ]
        },
        {
            "before": [ "<space>", "<space>" ],
            "after": [ "z", "M", "z", "v" ]
        }
    ],
    "vim.insertModeKeyBindings": [
        {
            "before": [ "j", "k" ],
            "after": [ "<Esc>" ]
        },
        {
            "before": [ "<c-f>" ],
            "after": [ "<Right>" ]
        },
        {
            "before": [ "<c-l>" ],
            "commands": [ "cursorRight" ]
        },
        {
            "before": [ "<c-h>" ],
            "commands": [ "cursorLeft" ]
        },
        {
            "before": [ "<c-j>" ],
            "commands": [ "cursorDown" ]
        },
        {
            "before": [ "<c-k>" ],
            "commands": [ "cursorUp" ]
        }
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [ ">" ],
            "after": [ ">", "g", "v" ]
        },
        {
            "before": [ "<" ],
            "after": [ "<", "g", "v" ]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [ "<C-w>", "l" ],
            "commands": [ "workbench.files.action.focusOpenEditorsView" ]
        },
        {
            "before": [ "<leader>", "n" ],
            "commands": [ ":nohl" ] 
        },
        {
            "before": [ "<leader>", "<tab>" ],
            "commands": [ ":q!" ]
        },
        {
            "before": [ "<leader>", "w" ],
            "commands": [ "workbench.action.splitEditor" ]
        },
        {
            "before": [ "<leader>", "E" ],
            "commands": [ "revealInExplorer" ] 
        },
        {
            "before": [ "<leader>", "e" ],
            "commands": [ "workbench.action.toggleSidebarVisibility" ]
        },
        {
            "before": [ "<leader>", "f", "f" ],
            "commands": [ "workbench.action.quickOpen" ]
        },
        {
            "before": [ "<leader>", "<s-f>"  ],
            "commands": [ "workbench.view.search" ]
        },
        // {
        //     "before": [
        //         "<leader>",
        //         "q",
        //     ],
        //     "commands": [
        //         "workbench.action.quickOpen"
        //     ]
        // },
        // {
        //     "before": [
        //         "<c-w>"
        //     ],
        //     "after": [],
        //     "command": [
        //         "workbench.action.terminal.kill"
        //     ]
        // },
        // {
        //     "before": [
        //         "<leader>",
        //         "<leader>",
        //     ],
        //     "commands": [
        //         "workbench.action.terminal.toggleTerminal"
        //     ]
        // },
        // {
        //     "before": [
        //         "<leader>",
        //         "<leader>",
        //     ],
        //     "commands": [
        //         "workbench.action.terminal.toggleTerminal"
        //     ],
        //     "when": "terminalFocus"
        // }
    ],
    "editor.fontSize": 10,
}
