{
  "editor.lineNumbers": "relative",
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": false,
  "workbench.startupEditor": "newUntitledFile",
  "editor.suggest.insertMode": "insert",
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "workbench.panel.defaultLocation": "right",
  "python.jediEnabled": false,
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.sneak": true,
  "vim.highlightedyank.enable": true,
  "vim.easymotionMarkerooundColor": "#020202",
  "vim.foldfix": true,
  "vim.leader": "<space>",
  "snippets.userSnippetsDirectory": "/home/mr00x/Dropbox/friendly-snippets",
  "snippets.extends": {},
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": true
  },
  "vim.normalModeKeyBindings": [
    {
      "before": ["s", "w"],
      "command": "workbench.action.evenEditorWidths"
    },
    {
      "before": ["g", "l"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      "before": ["g", "h"],
      "commands": ["workbench.action.previousEditor"]
    },
    {
      "before": ["K"],
      "commands": ["editor.action.showHover"]
    },
    {
      "before": ["<c-p>"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "F"],
      "commands": ["workbench.view.search"]
    },
    {
      "before": ["<c-g>"],
      "commands": ["actions.find"]
      // "after": ["/"]
    },
    {
      "before": ["<leader>", "q"],
      "commands": ["workbench.actions.view.problems"]
    },

    {
      "before": ["g", "S"],
      "commands": ["workbench.action.showAllSymbols"]
    },
    {
      "before": ["g", "s"],
      "commands": ["workbench.action.gotoSymbol"]
    },

    // Navigate
    {
      "before": ["s", "h"],
      "commands": ["workbench.action.focusLeftGroup"]
    },
    {
      "before": ["s", "l"],
      "commands": ["workbench.action.focusRightGroup"]
    },
    {
      "before": ["s", "k"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["s", "j"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["s", "j"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["s", "v"],
      "commands": ["workbench.action.splitEditor"]
    },
    {
      "before": ["s", "s"],
      "commands": ["workbench.action.splitEditorDown"]
    },
    {
      "before": ["s", "m"],
      "commands": ["workbench.action.maximizeEditor"]
    },

    {
      "before": ["z", "m"],
      "after": ["z", "M"]
    },
    {
      "before": ["<space>", "<space>"],
      "after": ["z", "M", "z", "v"]
    }
  ],
  "vim.insertModeKeyBindings": [
    {
      "before": ["h", "h"],
      "after": ["<Esc>"]
    },
    // Navigate
    {
      "before": "ctrl+b",
      "commands": "cursorWordLeft"
    },
    {
      "before": "ctrl+f",
      "commands": "cursorWordRight"
    },
    {
      "before": ["<c-l>"],
      "commands": ["cursorRight"]
    },
    {
      "before": ["<c-h>"],
      "commands": ["cursorLeft"]
    },
    {
      "before": ["<c-j>"],
      "commands": ["cursorDown"]
    },
    {
      "before": ["<c-k>"],
      "commands": ["cursorUp"]
    },
    {
      "before": ["<c-f>"],
      "after": ["<Right>"]
    },
    {
      "before": ["<c-b>"],
      "commands": ["cursorWordRight"]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": [">"],
      "after": [">", "g", "v"]
    },
    {
      "before": ["<"],
      "after": ["<", "g", "v"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    // DIAGNOSTIC ==================================================
    {
      "before": ["d", "n"],
      "commands": ["editor.action.marker.nextInFiles"],
      "silent": true
    },
    {
      "before": ["d", "p"],
      "commands": ["editor.action.marker.prevInFiles"],
      "silent": true
    },
    // LSP =========================================================
    {
      "before": ["g", "d"],
      "commands": ["editor.action.revealDefinition"],
      "silent": true
    },
    {
      "before": ["g", "r"],
      "commands": ["editor.action.goToReferences"],
      "silent": true
    },

    // GIT =========================================================
    // {
    //   "befor": ["g", "n"],
    //   "command": "workbench.action.editor.nextChange"
    //   //"when": "editorTextFocus"
    // },
    // {
    //   "key": "shift+alt+f5",
    //   "command": "workbench.action.editor.previousChange",
    //   "when": "editorTextFocus"
    // }

    // GLOBALS =====================================================
    // {
    //   "before": ["s", "f"],
    //   "commands": ["workbench.files.action.focusOpenEditorsView"]
    // },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "n"],
      "commands": [":nohl"]
    },
    {
      "before": ["<leader>", "<tab>"],
      "commands": [":q!"]
    }
  ],
  "editor.fontFamily": "'SF Mono', 'monospace', monospace",
  "editor.fontSize": 10,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "Sublime Material Theme - Dark",
  "window.zoomLevel": 2
}
