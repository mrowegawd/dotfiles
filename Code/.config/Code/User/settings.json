{
  // stole from: https://gist.github.com/ixahmedxi/b9a5a9105bfa39b72b914d9c56bb1cf3

  // ui
  "editor.minimap.enabled": false,
  "window.commandCenter": false,
  "editor.scrollbar.vertical": "auto",
  "window.titleBarStyle": "custom",
  "editor.scrollbar.horizontal": "auto",
  "workbench.editor.showTabs": "none",
  "editor.overviewRulerBorder": false,

  // APC
  "apc.activityBar": {
    "position": "bottom",
    "size": 28,
    "hideSettings": true
  },

  "apc.statusBar": {
    "position": "editor-bottom",
    "height": 28,
    "fontSize": 12
  },

  // Font size
  "editor.fontSize": 12,
  "terminal.integrated.fontSize": 12,
  "editor.fontFamily": "'SF Mono', 'monospace', monospace",

  // Misc
  "workbench.startupEditor": "none",
  // "workbench.startupEditor": "newUntitledFile",
  "explorer.compactFolders": false,
  "editor.tabSize": 2,
  "editor.linkedEditing": true,

  "workbench.colorCustomizations": {
    // "activityBar.background": "#6ff304",
    // "titleBar.activeBackground": "#69e024",
    // "titleBar.activeForeground": "#5809ce",
    // "icon.foreground": "#91ff00",
    "activityBar.border": "#6ff304",
    "symbolIcon.colorForeground": "#ff0000",
    "icon.colorForeground": "#ff0000",
    "activityBar.inactiveForeground": "#524747"
  },

  "breadcrumbs.filePath": "off",
  "files.trimTrailingWhitespace": true,
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "window.zoomLevel": 0.75,
  // "window.zoomLevel": 2

  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always"
  },
  "editor.lineNumbers": "relative",
  "editor.stickyScroll.enabled": true,
  "editor.suggest.insertMode": "insert",
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "workbench.panel.defaultLocation": "right",
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.sneak": true,
  "vim.highlightedyank.enable": true,
  "vim.foldfix": true,
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": true
  },

  // Toggle excluded files
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/.husky": true,
    "**/drizzle": true,
    "**/dist": true,
    "**/.todo.md": true,
    "**/.vscode": false,
    "**/.eslintrc.cjs": true,
    "**/.editorconfig": true,
    "**/.gitignore": true,
    "**/.lintstagedrc.mjs": true,
    "**/.markdownlint.json": true,
    "**/.markdownlintignore": true,
    "**/.prettierignore": true,
    "**/bun.lockb": true,
    "**/cspell.json": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/next-env.d.ts": true,
    "**/postcss.config.cjs": true,
    "**/prettier.config.js": true,
    "**/next.config.js": true,
    "**/tailwind.config.ts": true,
    "**/drizzle.config.ts": true,
    "**/migrate.ts": true,
    "**/.env.example": true
  },

  "vim.normalModeKeyBindings": [
    {
      // TODO: ini ga ngefek!
      // coba check ini: https://stackoverflow.com/questions/46812455/vs-code-how-to-resize-editor-window-without-resizing-the-whole-interface
      "before": ["s", "w"],
      "command": "workbench.action.evenEditorWidths"
    },
    {
      "before": ["<c-p>"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "F"],
      "commands": ["workbench.view.search"]
    },
    {
      "before": ["<leader>", "f", "g"],
      "commands": ["workbench.view.search"]
    },
    {
      "before": ["<c-g>"],
      "after": ["/"]
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"]
    },
    {
      "before": ["<leader>", "n"],
      "commands": [":nohl"]
    },
    {
      "before": ["<leader>", "<tab>"],
      "commands": [":q!"]
    },
    {
      "before": [",", "o", "a"],
      "commands": ["workbench.action.toggleAuxiliaryBar"]
    },

    // -------------------------
    // NAVIGATE
    // -------------------------

    {
      // next buffer
      "before": ["g", "l"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      // prev buffer
      "before": ["g", "h"],
      "commands": ["workbench.action.previousEditor"]
    },
    {
      "before": ["s", "h"],
      "commands": ["workbench.action.focusLeftGroup"]
    },
    {
      "before": ["s", "l"],
      "commands": ["workbench.action.focusRightGroup"]
    },
    {
      "before": ["s", "k"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["s", "j"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["s", "j"],
      "commands": ["workbench.action.focusAboveGroup"]
    },
    {
      "before": ["s", "v"],
      "commands": ["workbench.action.splitEditor"]
    },
    {
      "before": ["s", "s"],
      "commands": ["workbench.action.splitEditorDown"]
    },
    {
      "before": ["s", "m"],
      "commands": ["workbench.action.maximizeEditor"]
    },

    {
      // force window view to horizontal view,
      // tapi command ini membuat cursor malah menjadi out of window??
      // dunno idk how to fix this :(
      "before": ["s", "J"],
      "commands": ["workbench.action.toggleEditorGroupLayout"]
    },
    {
      // force to vertical
      "before": ["s", "L"],
      "commands": ["workbench.action.toggleEditorGroupLayout"]
    },

    // -------------------------
    // BOOKMARKS & MARKS
    // -------------------------
    {
      "before": ["m", "`"],
      "commands": ["bookmarks.toggle"]
      // "command": "bookmarks.toggle",
      // "when": "editorTextFocus"
    },
    {
      "before": ["d", "m"],
      "commands": ["bookmarks.toggle"]
      // "command": "bookmarks.toggle",
      // "when": "editorTextFocus"
    },
    {
      "before": ["d", "M"],
      "commands": ["bookmarks.clearFromAllFiles"]
    },
    {
      "before": ["s", "n"],
      "commands": ["bookmarks.jumpToNext"]
      // "when": "editorTextFocus"
    },
    {
      "before": ["s", "p"],
      "commands": ["bookmarks.jumpToPrevious"]
    },
    {
      "before": ["m", "F"],
      "commands": ["bookmarks.listFromAllFiles"]
    },

    // -------------------------
    // FOLD
    // -------------------------
    {
      "before": ["z", "m"],
      "after": ["z", "M"]
    },
    {
      "before": ["<space>", "<space>"],
      "after": ["z", "M", "z", "v"]
    },

    // -------------------------
    // GIT
    // -------------------------
    {
      // move cursor to the next hunk
      "before": ["g", "n"],
      "commands": ["workbench.action.editor.nextChange"]
    },
    {
      // move cursor to the prev hunk
      "before": ["g", "p"],
      "commands": ["workbench.action.editor.previousChange"]
    },

    {
      "before": ["<leader>", "g", "t", "b"],
      "commands": ["gitlens.toggleCodeLens"]
    },
    {
      "before": ["<leader>", "g", "t", "B"],
      "commands": ["gitlens.toggleFileBlame"]
    },

    // -------------------------
    // LSP
    // -------------------------

    {
      "before": ["g", "S"],
      "commands": ["workbench.action.showAllSymbols"]
    },
    {
      "before": ["g", "s"],
      "commands": ["workbench.action.gotoSymbol"]
    },

    {
      "before": ["K"],
      "commands": ["editor.action.showHover"]
    },
    {
      "before": ["g", "d"],
      "commands": ["editor.action.revealDefinition"],
      "silent": true
    },
    {
      "before": ["<F2>"],
      "commands": ["editor.action.goToReferences"],
      "silent": true
    },

    {
      "before": ["g", "R"],
      "commands": ["references-view.findReferences"],
      "silent": true
    },

    {
      "before": ["g", "r"],
      "commands": ["editor.action.goToReferences"],
      "silent": true
    },

    {
      "before": ["g", "P"],
      "commands": ["editor.action.peekTypeDefinition"],
      "silent": true
    },

    {
      "before": ["g", "t"],
      "commands": ["editor.action.goToTypeDefinition"],
      "silent": true
    },

    {
      "before": ["g", "I"],
      "commands": ["editor.showCallHierarchy"],
      "silent": true
    },

    {
      "before": ["g", "O"],
      "commands": ["editor.showOutgoingCalls"],
      "silent": true
    },

    // {
    //   "key": "shift+alt+h",
    //   "command": "editor.showCallHierarchy",
    //   "when": "editorHasCallHierarchyProvider && editorTextFocus && !inReferenceSearchEditor"
    // }
    // -------------------------
    // DIAGNOSTIC
    // -------------------------
    {
      "before": ["<leader>", "q"],
      "commands": ["workbench.actions.view.problems"]
    },

    {
      "before": ["d", "n"],
      "commands": ["editor.action.marker.nextInFiles"],
      "silent": true
    },
    {
      "before": ["d", "p"],
      "commands": ["editor.action.marker.prevInFiles"],
      "silent": true
    },
    {
      "before": ["<leader>", "x", "x"],
      "commands": ["workbench.actions.view.problems"],
      "silent": true
    },

    // -------------------------
    // TASK
    // -------------------------
    {
      "before": ["r", "f"],
      "commands": ["workbench.action.tasks.runTask"]
    },

    // -------------------------
    // DEBUG
    // -------------------------
    {
      "before": ["<leader>", "<F5>"],
      "commands": ["workbench.action.debug.stop"],
      // "when": "inDebugMode && !focusedSessionIsAttach"
      "silent": true
    },
    {
      "before": ["<leader>", "d", "b"],
      "commands": ["editor.debug.action.toggleBreakpoint"],
      "silent": true
    },
    {
      "before": ["<leader>", "d", "B"],
      "commands": ["workbench.debug.viewlet.action.removeAllBreakpoints"],
      "silent": true
    },

    {
      "before": ["<leader>", "d", "R"],
      "commands": ["workbench.debug.action.toggleRepl"],
      // "when": "workbench.panel.repl.view.active"
      "silent": true
    }
  ],
  "vim.insertModeKeyBindings": [
    {
      "before": ["h", "h"],
      "after": ["<Esc>"]
    },

    {
      // go next character
      "before": ["<c-l>"],
      "commands": ["cursorRight"]
    },

    {
      // go prev character
      "before": ["<c-h>"],
      "commands": ["cursorLeft"]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": [">"],
      "after": [">", "g", "v"]
    },
    {
      "before": ["<"],
      "after": ["<", "g", "v"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [],
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "Aura Dark",
  "breadcrumbs.enabled": false,
  "settingsSync.keybindingsPerPlatform": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "gitlens.codeLens.enabled": false,

  // ----------------------------------------
  // PYTHON
  // ----------------------------------------
  "python.analysis.typeCheckingMode": "strict",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "go.toolsManagement.autoUpdate": true
}
