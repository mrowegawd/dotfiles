[
  // -------------------------
  // Reset zoom
  // -------------------------
  {
    "key": "ctrl+Home",
    "command": "workbench.action.zoomReset"
  },
  {
    "key": "escape",
    "command": "-editor.action.cancelSelectionAnchor",
    "when": "editorTextFocus && selectionAnchorSet"
  },

  // Navigate go/back fast word (when insert mode)
  {
    "key": "ctrl+b",
    "command": "cursorWordLeft",
    "when": "vim.active && vim.mode == 'Insert'"
  },
  {
    "key": "ctrl+f",
    "command": "cursorWordRight",
    "when": "vim.active && vim.mode == 'Insert'"
  },
  // {
  //   "key": "ctrl+a",
  //   "command": "cursorHome",
  //   "when": "textInputFocus"
  // },
  // {
  //   "key": "ctrl+e",
  //   "command": "cursorEnd",
  //   "when": "textInputFocus"
  // },

  // Traverse VSCode IntelliSense suggestions with vim keybindings.
  {
    "key": "ctrl+j",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
  },
  {
    "key": "ctrl+l",
    "command": "acceptSelectedSuggestion",
    "when": "acceptSuggestionOnEnter && suggestWidgetHasFocusedSuggestion && suggestWidgetVisible && suggestionMakesTextEdit && textInputFocus"
  },

  // Traverse VSCode quick open options with vim keybindings.
  {
    "key": "ctrl+j",
    "command": "workbench.action.quickOpenNavigateNextInFilePicker",
    "when": "inFilesPicker && inQuickOpen"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.quickOpenNavigatePreviousInFilePicker",
    "when": "inFilesPicker && inQuickOpen"
  },

  // Open VSCode quick open in split mode
  // ini tidak berhasil, ctrl+v malah jadi paste!
  // {
  //   "key": "ctrl+v",
  //   "command": "breadcrumbs.revealFocusedFromTreeAside",
  //   "when": "inQuickOpen && breadcrumbsActive && breadcrumbsVisible && listFocus && !inputFocus && !treestickyScrollFocused"
  // },

  // -------------------------
  // Navigate Window
  // -------------------------
  {
    "key": "alt+h",
    "command": "workbench.action.navigateLeft"
  },
  {
    "key": "alt+l",
    "command": "workbench.action.navigateRight"
  },
  {
    "key": "alt+k",
    "command": "workbench.action.navigateUp"
  },
  {
    "key": "alt+j",
    "command": "workbench.action.navigateDown"
  },

  // -------------------------
  // Resize window
  // -------------------------
  {
    "key": "shift+alt+l",
    "command": "workbench.action.increaseViewSize"
  },
  {
    "key": "shift+alt+k",
    "command": "workbench.action.increaseViewSize"
  },
  {
    "key": "shift+alt+h",
    "command": "workbench.action.decreaseViewSize"
  },
  {
    "key": "shift+alt+j",
    "command": "workbench.action.decreaseViewSize"
  },

  // -------------------------
  // Terminal
  // -------------------------
  {
    "key": "alt+f",
    "command": "workbench.action.terminal.toggleTerminal"
  },
  {
    "key": "ctrl+Insert",
    "command": "workbench.action.terminal.new",
    "when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
  },
  {
    "key": "ctrl+End",
    "command": "workbench.action.terminal.kill",
    "when": "terminalProcessSupported || terminalWebExtensionContributedProfile"
  },

  // -------------------------
  // Explorer Sidebars
  // -------------------------
  {
    "key": "alt+e",
    "command": "workbench.action.toggleSidebarVisibility"
  },
  {
    "key": "alt+shift+e",
    "command": "revealInExplorer"
  },

  {
    // Open selected file in the first (left) editor group from File Explorer
    "key": "ctrl+v",
    "command": "explorer.openToSide",
    "args": { "group": 0 },
    "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus"
  },
  {
    // Open selected file in the second (right) editor group from File Explorer
    "key": "ctrl+s",
    "command": "explorer.openToSide",
    "args": { "group": 1 },
    "when": "explorerViewletVisible && filesExplorerFocus && !inputFocus"
  },
  {
    "key": "alt+9",
    "command": "outline-map.focusSearch"
  },
  {
    "key": "alt+l",
    "command": "-outline-map.focusSearch"
  },
  {
    "key": "ctrl+shift+e",
    "command": "-workbench.view.explorer",
    "when": "viewContainer.workbench.view.explorer.enabled"
  },
  {
    "key": "ctrl+j",
    "command": "-workbench.action.togglePanel"
  }
]
