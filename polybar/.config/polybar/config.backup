# vim: foldmethod=marker foldlevel=0 ft=dosini
# ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ
# ‚ĖĎ‚Ėą‚ĖÄ‚ĖÄ‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ
# ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ
# #########################################
# BARSET ---------------------------------- {{{
# ------------------------ [global/wm]
[global/wm]
margin-bottom       = 2
margin-top          = 2

[colors]
iconfg              = ${xrdb:color5}
warnfg              = ${xrdb:color3}
redfg               = ${xrdb:color9}
nofg                = ${xrdb:color4}

foreground          = ${xrdb:foreground}
background-bubble   = #2b2f37
; background-bubble   = #363c4a
; background-bubble   = ${xrdb:color11}
background          = ${xrdb:background}

[section/bar]
monitor             = DP-2

font-0              = mononoki Nerd Font:size=9:style=regular;1
font-1              = TerminessTTF Nerd Font:size=10:style=bold;1
font-2              = Siji:size=10:fontformat=truetype;style=regular;1
font-3              = Wucon Siji:size=1:style=regular;1

; override-redirect   = true

[bar/top]

inherit             = section/bar
width               = 100%
enable-ipc          = true
padding-left        = 1
padding-right       = 1
line-size           = 2

; Use either of the following command to list available outputs:
; If unspecified, the application will pick the first one it finds.
; $ polybar -m | cut -d ':' -f 1
; $ xrandr -q | grep " connected" | cut -d ' ' -f1
monitor = ${env:MONITOR:}

; Use the specified monitor as a fallback if the main one is not found.
monitor-fallback =

; Require the monitor to be in connected state
; XRandR sometimes reports my monitor as being disconnected (when in use)
monitor-strict = false

; Tell the Window Manager not to configure the window.
; Use this to detach the bar if your WM is locking its size/position.
override-redirect = false

; Put the bar at the bottom of the screen
bottom = false

; Prefer fixed center position for the `modules-center` block
; When false, the center position will be based on the size of the other blocks.
fixed-center = true

; Dimension defined as pixel value (e.g. 35) or percentage (e.g. 50%),
; the percentage can optionally be extended with a pixel offset like so:
; 50%:-10, this will result in a width or height of 50% minus 10 pixels
; width = 2.2%
height = 35

; Offset defined as pixel value (e.g. 35) or percentage (e.g. 50%)
; the percentage can optionally be extended with a pixel offset like so:
; 50%:-10, this will result in an offset in the x or y direction
; of 50% minus 10 pixels
; offset-x = 2.95%
; offset-y = 1%

border-top-size     = 6
border-bottom-size  = 6
border-top-color    = ${colors.background}
border-bottom-color = ${colors.background}

; background        = #5a000000
background          = ${colors.background}
foreground          = ${colors.foreground}

; modules-right     = pomo pulseaudio updates network memory filesystem powermenu
modules-left        = appmenu round-left bspwm round-right round-left mpd round-right
modules-right       = pulseaudio round-left updates network temperature memory filesystem uptime round-right round-left time round-right powermenu

tray-position       = right
tray-padding        = 3

; wm-restack          = i3
#
# }}}

# #########################################
# X - WINDOW ------------------------------ {{{
[module/xwindow]
type = internal/xwindow
format-prefix = "Ôčí: "
format-prefix-foreground = ${colors.iconfg}
format = %{A1:rofi -show drun:}<label>%{A}
label = "%title:0:38:...%"
label-empty =

# }}}

# #########################################
# SYS ------------------------------------- {{{
[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 70
format-warn = <ramp> <label-warn>
format-warn-background = ${colors.redfg}

format = <ramp> <label>
format-foreground = ${colors.foreground}
format-background = ${colors.background-bubble}
format-padding = 1

label = %temperature-c%
label-warn = %temperature-c%

ramp-0 = Ôčč
ramp-1 = Ôčä
ramp-2 = ÔčČ
ramp-3 = Ôčą
ramp-4 = Ôčá

[module/filesystem]
type = internal/fs
interval = 3600

mount-0 = /

format-mounted-prefix = %{T2}ÔÄē %{T-}
format-mounted-prefix-foreground = ${colors.foreground}
; format-mounted-overline = ${colors.redfg}
format-mounted-padding = 1
format-mounted-background = ${colors.background-bubble}

label-mounted = %percentage_used%%
label-mounted-foreground = ${colors.foreground}

; label-mounted = %{T2} %percentage_used%%
; label-unmounted = %mountpoint% not mounted
; label-unmounted-foreground = ${colors.nofg}

[module/memory]
type = internal/memory
; type = custom/script
; exec = free -m | sed -n 's/^Mem:\s\+[0-9]\+\s\+\([0-9]\+\)\s.\+/\1/p'

; format = <label>
; format-prefix = %{T2}Ô¨ô %{T-}
; format-prefix-foreground = #d19a66
; format-foreground = #d19a66
; format-background = #2b2f37
; format-padding = 1

; label = %output% MB

interval = 2

format = <label>
format-prefix = %{T2}Ô¨ô %{T-}
; format-prefix-foreground = ${colors.nofg}
format-foreground = ${colors.foreground}
format-background = ${colors.background-bubble}
format-padding = 1

label = %percentage_used%%
; label = %gb_used%/%gb_total%

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 0

label-open = %{T2}ÔÄĎ%{T-}
label-open-foreground = ${colors.redfg}
label-open-padding = 1

label-close = %{T2}Ôįł%{T-}
label-close-foreground = ${xrdb:color7}
label-close-padding = 1

menu-0-0 = %{T2}ÔÄě%{T-}
menu-0-0-exec = menu-open-1
menu-0-0-padding = 1

menu-0-1 = %{T2}‚Źľ%{T-}
menu-0-1-exec = menu-open-2
menu-0-1-padding = 1

menu-1-0 = %{T2}ÔÄě%{T-}
menu-1-0-exec = systemctl reboot
menu-1-0-padding = 1

menu-1-1 = %{T2}ÔÄć%{T-}
menu-1-1-exec = menu-open-0
menu-1-1-padding = 1

menu-2-0 = %{T2}ÔÄć%{T-}
menu-2-0-exec = menu-open-0
menu-2-0-padding = 1

menu-2-1 = %{T2}‚Źľ%{T-}
menu-2-1-exec = systemctl poweroff
menu-2-1-padding = 1

[module/backlight]
type = internal/backlight

card = intel_backlight
format = <ramp> <label>
ramp-foreground = ${colors.foreground}
label-foreground = ${colors.foreground}
label = %percentage%%

ramp-0 = ÔóĚ
ramp-1 = Ôóú
ramp-2 = Ôóü

# }}}

# #########################################
# WINDOW MANAGER -------------------------- {{{
[module/bspwm]
type           = internal/bspwm
pin-workspaces = true
enable-click   = true
enable-scroll  = true
reverse-scroll = false
inline-mode    = false
format         = <label-state>

; label-focused          = Ô§Ĺ
; label-occupied         = Ô§ľ
;
; ws-icon-0              = "Browser;ÓÜ†"
; ws-icon-1              = "Terminal;ÓáĮ"
; ws-icon-2              = "Code;ÓáĮ"
; ws-icon-3              = "Messaging;ÓÜß"
; ws-icon-4              = "Mail;ÓÜ®"
; ws-icon-5              = "Music;ÓĀć"
; ws-icon-6              = "Games;Óā™"
; ws-icon-7              = "Reader;Óáē"

label-separator-background = ${colors.background-bubble}
; ws-icon-0 = 1;%{F#F9DE8F}Ô¨Ď
; ws-icon-1 = 2;%{F#ff9b93}ÔČ®
; ws-icon-2 = 3;%{F#95e1d3}ÔČ•

ws-icon-0 = 1;Ô¨Ď
ws-icon-1 = 2;ÔČ®
ws-icon-2 = 3;ÔČ•
ws-icon-3 = 4;ÔÉ†
ws-icon-4 = 5;ÔÜė
ws-icon-5 = 6;+

label-focused = %icon%
label-focused-foreground = ${colors.redfg}
label-focused-background = ${colors.background-bubble}
label-focused-underline =  ${colors.redfg}
label-focused-padding = 1

label-occupied = %icon%
label-occupied-foreground = ${colors.nofg}
label-occupied-background = ${colors.background-bubble}
label-occupied-padding = 1

label-urgent = %icon%
label-urgent-foreground = ${colors.background}
label-urgent-background = ${colors.warnfg}
label-urgent-padding = 1

label-empty = %icon%
label-empty-foreground = ${colors.foreground}
label-empty-background = ${colors.background-bubble}

label-empty-padding = 1

; [module/i3]
; type = internal/i3
; format = <label-state><label-mode>
; index-sort = true
; enable-click = false
; enable-scroll = false
; content-padding = 1
;
; ws-icon-0 = 1;ÔÄē
; ws-icon-1 = 2;ÔĄ†
; ws-icon-2 = 3;ÔČ©
; ws-icon-3 = 4;ÔĀĽ
; ws-icon-4 = 5;ÔÜľ
; ws-icon-5 = 6;ÔÜ∂
; ws-icon-6 = 7;ÔÄô
; ws-icon-7 = 8;ÔĄ°
; ws-icon-8 = 9;Ôéí
; ws-icon-default = I
;
; ; Only show workspaces on the same output as the bar
; pin-workspaces = true
;
; ; focused = Active workspace on focused monitor
; label-focused = " Ô§Ĺ "
; label-focused-background =
; label-focused-foreground = ${xrdb:color6}
; label-focused-underline =
; ; label-focused-padding = 1
;
; ; unfocused = Inactive workspace on any monitor
; ; label-unfocused =
; label-unfocused = " Ô§ľ "
; label-unfocused-foreground = ${xrdb:color6}
; label-unfocused-underline =
; ; label-unfocused-padding = 1
;
; ; visible = Active workspace on unfocused monitor
; label-visible =
; label-visible-background = ${xrdb:color5}
; label-visible-underline = ${xrdb:color5}
; ; label-visible-padding = 1
;
; ; urgent = Workspace with urgency hint set
; label-urgent = " ÔĄĎ "
; label-urgent-foreground= ${xrdb:color3}
; ; label-urgent-padding = 1
# }}}

# #########################################
# MULTIMEDIA ------------------------------ {{{
; [module/mpd]
; type = internal/mpd
; format-online = <toggle>
; format-offline =
; label-song = %artist% - %title%
; label-song-padding = 4
; label-time = (%elapsed%/%total%)
; icon-play-foreground = ${xrdb:color8}
; icon-play = ÔĘÜ
; icon-pause = ÔĘÜ
[module/mpd]
type = internal/mpd

host = 127.0.0.1
port = 6600
;
; format-online = <icon-prev> <toggle> <icon-next> <label-time> | <label-song>
;
; label-song = %artist:0:30:...% - %title:0:30:...%
;
; format-offline-foreground = ${xrdb:color15}
; label-offline = ÔĀĪ mpd is offline
;
; icon-play = ÔĀč
; icon-pause = ÔĀĆ
; icon-stop = ÔĀć
; icon-prev = ÔĀą
; icon-next = ÔĀĎ
; icon-seekb = ÔĀä
; icon-seekf = ÔĀé
; icon-random = ÔĀī
; icon-repeat = ÔÄě
;
; ; Only applies if <bar-progress> is used
; bar-progress-width = 10
; bar-progress-indicator = |
; bar-progress-fill = ‚ĒÄ
; bar-progress-empty = ‚ĒÄ

; format-online = %{T2}<icon-prev> <toggle> <icon-next> <label-time>%{T-} <label-song>
format-online = %{T2}<icon-prev> <toggle> <icon-next>%{T-} <label-song>
format-online-padding = 1
format-online-background = ${colors.background-bubble}

label-song = | %artist:0:10:...% - %title:0:10:...%

icon-prev = ÔĀą
icon-play = ÔĀč
icon-pause = ÔĀĆ
icon-next =  ÔĀĎ

toggle-on-foreground = ${colors.foreground}
toggle-off-foreground = ${colors.foreground}
label-offline = no sound

[module/pulseaudio]
type = internal/pulseaudio
; ; Sink to be used, if it exists (find using `pacmd list-sinks`, name field)
; ; If not, uses default sink
sink = alsa_output.pci-0000_00_1f.3.analog-stereo

format-volume-prefix = %{T2}Ô©Ĺ %{T-}
format-volume = %{T1}<label-volume>%{T-}
format-volume-padding = 1
; format-volume-background = ${xrdb:color3}

; label = <format-volume>
; label-volume-background = ${xrdb:color3}
; label-volume-padding = 1

format-muted-prefix = %{T2}Ô©ĺ %{T-}
format-muted-prefix-foreground = ${colors.nofg}
; format-muted-background = ${xrdb:color3}
format-muted-padding = 1

label-muted = muted
label-muted-foreground = ${colors.nofg}
; label-muted-padding = 1

# }}}

# #########################################
# INTERNET -------------------------------- {{{
[module/network]
type = internal/network
interface = enp0s31f6
interval = 3

format-disconnected = <label-disconnected>
format-packageloss = <label-packageloss>
format-connected = <label-connected>

format = <label>
; format-padding = 1
; format-background = ${colors.background-bubble}
; format-foreground = ${colors.foreground}

label-connected = %{T2}ÔÄô %{T-}%{T1}%downspeed:7%%{T-}
label-connected-background = ${colors.background-bubble}
label-connected-padding = 1

label-disconnected = Ô†ė
label-disconnected-foreground = ${colors.redfg}
label-disconnected-background = ${colors.background-bubble}
label-disconnected-padding = 1

label-packageloss = Ô†ė
label-packageloss-foreground = ${colors.redfg}
label-packageloss-background = ${colors.background-bubble}
label-packageloss-padding = 1

# }}}

# #########################################
# TIME ------------------------------------ {{{
[module/time]
type = internal/date
interval = 60
; interval = 5
; date = %a, %d %B %Y
; date-alt  = %H:%M %p
; time = %H:%M
; label = " %{T4}%time% %date%%{T-} "
; label-foreground = ${xrdb:color3}
; time-alt = %H:%M
; label-background = ${colors.background-alt}

; format-prefix = " ÔÄó :"
; format-prefix-foreground = ${xrdb:color0}
; format-prefix-background = ${xrdb:color8}
; label-background = ${xrdb:color0}
; format = <label>
format-background = ${colors.background-bubble}
format-foreground = ${colors.warnfg}
format-padding = 1

time = %{T2}ÔÄó %{T-} %H:%M

; date-alt = " %d-%m-%Y"
; date-alt = " %b %d %Y"
date-alt = %A, %d %B %Y
; time-alt = " %H:%M "

; time-alt = %{F#61afef}ůįÉ≠ %a, %b %d%{F-}

label = %date%%time%


# }}}

# #########################################
# MISC ------------------------------------ {{{
; [section/batterymodule]
; type = internal/battery
; poll-interval = 5
; time-format = %H:%M
; format-charging = <ramp-capacity> ÔÉß
; format-discharging = <ramp-capacity>
; format-full = Ôá¶
; ramp-capacity-0-foreground = ${xrdb:color1}
; ramp-capacity-0 = ÔČĄ
; ramp-capacity-1 = ÔČĄ
; ramp-capacity-2 = ÔČÉ
; ramp-capacity-3 = ÔČÉ
; ramp-capacity-4 = ÔČā
; ramp-capacity-5 = ÔČā
; ramp-capacity-6 = ÔČĀ
; ramp-capacity-7 = ÔČĀ
; ramp-capacity-8 = ÔČÄ
; ramp-capacity-9 = ÔČÄ

# }}}

# #########################################
# CUSTOM SCRIPT --------------------------- {{{
# ------------------------
[module/custom-network]
type = custom/script
exec = ~/.config/polybar/scripts/check-network
tail = true
interval = 3

format = <label>
format-padding = 1
format-background = ${colors.background-bubble}
format-foreground = ${colors.foreground}
label = %{T2}%output% %{T-}

click-left = st -e nmtui-connect
click-right = st -e nmtui-edit

[module/pomo]
type = custom/script
exec = ~/.local/bin/pomo status
interval = 1

format = <label>
format-padding = 1
label =%{T2}Ô®ö%{T-} %output%
; label-padding = 1

[module/updates]
type = custom/script
exec = ~/.config/polybar/scripts/checkupdates.sh
interval = 4600

format = <label>
format-background = ${colors.background-bubble}

label =%{T2}Ôā™ %{T-}%output%
label-padding = 1
label-foreground = ${colors.foreground}

; [module/spotify]
; type = custom/script
; interval = 1
; format-prefix = "ÔÉā : "
; format = <label>
; exec = python3 ~/.config/polybar/scripts/spotify-status.py -f '{artist} - {song}'
; format-prefix-foreground = ${colors.iconfg}
; format-padding = 1

[module/appmenu]
type = custom/text
content = %{T2}ÔĆÜ %{T-}
content-padding = 1
content-foreground = ${colors.iconfg}
; content-background = ${xrdb:color6}

click-left = rofi -show window
click-middle = rofi -show ssh
click-right = rofi -show drun

[module/uptime]
;https://github.com/jaagr/polybar/wiki/User-contributed-modules#uptime
type = custom/script
exec = uptime | awk -F, '{sub(".*up ",x,$1);print $1}'
interval = 100
label = %output%

format-foreground = ${colors.nofg}
format-background = ${colors.background-bubble}
format-prefix = "ÔĄą "
format-padding = 1


# }}}

# #########################################
# SEPARATOR ------------------------------- {{{
# ------------------------
; [module/separator]
; type = custom/text
; content = "WINDOW:"
[module/round-left]
type = custom/text
content = %{T2}Óā∂%{T-}
content-foreground = ${colors.background-bubble}

[module/round-right]
type = custom/text
content = %{T2}Óāī%{T-}
content-foreground = ${colors.background-bubble}

# }}}
