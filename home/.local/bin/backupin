#!/bin/bash

# Read this!
# `false`, jika kamu ingin backup dengan toggle on-off dropbox dan `true`
# berlaku sebalik nya.
SHUTDOWN_DROPBOX="false"

function __backup_and_turnonoff_dropbox() {
  DROPBOX_STATUS=$(dropbox status)

  pidof_dropbox=$(pidof dropbox)
  [[ -z $pidof_dropbox ]] && dropbox stop
  sleep 10

  if [ "$DROPBOX_STATUS" == "Dropbox isn't running!" ]; then
    dropbox start >/dev/null
    sleep 30

    if [ -f "$HOME/.local/bin/mysyncthing" ]; then
      "$HOME/.local/bin/mysyncthing" >/dev/null
      sleep 10

      # to stop the syncthing
      # docker stop $(docker ps -aqf "name=mysyncthing")
    fi

    dropbox stop >/dev/null
  fi

}

if [ $SHUTDOWN_DROPBOX == "true" ]; then
  __backup_and_turnonoff_dropbox
else
  "$HOME/.local/bin/mysyncthing" >/dev/null
fi
