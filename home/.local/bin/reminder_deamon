#!/bin/bash

XAUTHORITY=/home/$USER/.Xauthority

export XAUTHORITY

# notifme() {
#   rem -az | while read -r SPAM_OUT; do
#     [[ ! -z $SPAM_OUT ]] && notify-send -t 100001 "$SPAM_OUT" -i "/home/$USER/.config/dunst/checklist.png" &&
#       mpv --audio-display=no ~/.config/dunst/notif-me.wav --volume=30
#   done &
# }

pid=$(ps -C rem -o pid=)

if [ -n "$pid" ]; then
  #Remind is running so restart it
  kill "$pid"
  # rem -az | while read -r SPAM_OUT; do notify-send -t 100000 "$SPAM_OUT"; done &
  rem -az | while read -r SPAM_OUT; do
    [[ ! -z $SPAM_OUT ]] && notify-send -t 100001 "$SPAM_OUT" -i "/home/$USER/.config/dunst/checklist.png" &&
      mpv --audio-display=no ~/.config/dunst/notif-me.wav --volume=30
  done &
else
  #Remind is NOT running so start it
  rem -az | while read -r SPAM_OUT; do
    [[ ! -z $SPAM_OUT ]] && notify-send -t 100001 "$SPAM_OUT" -i "/home/$USER/.config/dunst/checklist.png" &&
      mpv --audio-display=no ~/.config/dunst/notif-me.wav --volume=30
  done &
fi

exit
