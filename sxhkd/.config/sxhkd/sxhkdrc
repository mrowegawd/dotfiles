#         xbacklight -dec 5

########################################
# misc
########################################

# misc: open rofi_call
super + u
        $HOME/.config/rofi/menu/menu.sh

# misc: open terminal
super + Return
        st
        # alacritty -e tmux
        # kitty
        # wezterm
        # kitty -o allow_remote_control=yes --single-instance --listen-on unix:@mykitty

# misc: kill/close window
super + Tab
        xdo close

# misc: increase volume
super + shift + equal
        amixer -q sset Master 3%+

# misc: decrease volume
super + shift + minus
        amixer -q sset Master 3%-

# misc: mute toggle
super + shift + m
        amixer -q sset Master toggle

# misc: reload sxhkd
super + shift + F8
        pkill -USR1 -x sxhkd && SLEEP=2 dunstify "Reload SXHKD:" "Reload config.."

# misc: restart/reload bspwm
super + shift + F12
        bspc wm -r && SLEEP=2 dunstify "Reload BSPWM"  "Reload config.."

# misc: change background img
super + shift + Home
        $HOME/Dropbox/exbin/for-local-bin/fehbg

# misc: open tools
super + shift + t
        $HOME/.config/rofi/menu/_tools

# misc: open ncmpcpp
super + shift + n
        $HOME/Dropbox/exbin/for-local-bin/bspwmfloat ncmpcpp

# misc: run glinux
super + shift + g
        $HOME/.config/rofi/menu/_glinux

# misc: run obsidian
super + shift + o
        bspc rule -a \* -o state=floating st && st

# misc: panggill firefox lalu set di sisi kiri (side by side)
super + F4
        $HOME/Dropbox/exbin/for-local-bin/bspc_firefox

# misc: run create note
super + shift + u
        bspc rule -a \* -o state=floating center=true rectangle=800x500+0+0 && kitty -e bash -c "/usr/local/bin/nvim -c 'lua require(\"orgmode\").action(\"capture.prompt\") vim.cmd[[nmap <c-c> :exit<cr>]]'"
        # bspc rule -a \* -o state=floating center=true rectangle=800x500+0+0 && sh -e bash -c "/usr/local/bin/nvim --noplugin -c 'lua require(\"orgmode\").action(\"capture.prompt\") vim.cmd[[nmap <c-c> :exit<cr>]]'"

# misc: run websearch bookmark
super + shift + p
        ~/.local/bin/websearch

# misc: poweroff
super + shift + q
        $HOME/.config/rofi/powermenu/poweroff.sh

# misc: run mpv
super + shift + y
        dunstify "Running vid on tsp" "$(xclip -o -sel clip)" && tsp mpv -ontop -no-border -force-window --autofit=400x300 --geometry=-15-60 "$3" $(xclip -o -sel clip)

